#ifndef __CIVL_CIVLMPI__
#define __CIVL_CIVLMPI__
/* Filename : civl-mpi-blocking.cvl
   Author   : Ziqing Luo and Stephen Siegel
   Created  :
   Modified : 2026-06-05

   This module implements civl-mpi.cvh, a library of message-passing
   routines used to help implement the MPI library.  It is optimized
   for programs that perform blocking MPI operations only.
   Nonblocking operations are not supported.

   This module uses the Collective Monitor defined in cmon.cvh
   to ensure consistency of collective calls across processes.
 */
#include <civl-mpi.cvh>
#include <cmon.cvh>
#include <pointer.cvh>
#include <seq.cvh>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// Type definitions...

/* MPI communicator object.  MPI_Comm is a pointer to this type, which
   is declared in mpi.h */
struct CIVL_MPI_Comm {
  $scope gscope; // the shared (global) scope, scope of the gcomm
  $scope scope; // the MPI process scope
  $comm p2p; // CIVL comm used for point-to-point communication
  $comm col; // CIVL comm used for collective communication
  $barrier barrier;
  int gcommIndex; //the index of the corresponding global communicator.
  $cmon cm; // collective monitor
};

// global communicator state.  declared in civl-mpi.cvh
struct $mpi_gcomm {
  $scope scope; // the shared scope containing the process scope
  $gcomm p2p; // point-to-point communication
  $gcomm col; // collective communication
  $gbarrier gbarrier;
  $cmon_g cmg; // global collective monitor
};

// Misc. MPI support functions...

static void bcast
(void *buf, int count, MPI_Datatype datatype, int root,
 int tag, MPI_Comm comm, char * routName)
{
  int rank = $mpi_comm_place(comm);
  if (rank == root) {
    int nprocs = $mpi_comm_size(comm);
    for (int i=0; i<nprocs; i++)
      if (i != root)
	$mpi_collective_send(buf, count, datatype, i, tag, comm);
  } else
    $mpi_collective_recv(buf, count, datatype, root, tag, comm,
			 MPI_STATUS_IGNORE, routName);
}

static void gather
(const void* sendbuf, int sendcount, MPI_Datatype sendtype, 
 void* recvbuf, int recvcount, MPI_Datatype recvtype, 
 int root, int tag, MPI_Comm comm, char * routName)
{
  int rank = $mpi_comm_place(comm), nprocs = $mpi_comm_size(comm);
  if (rank == root) {
    if (sendbuf != MPI_IN_PLACE)
      memcpy($mpi_pointer_add(recvbuf, root * recvcount, recvtype),
	     sendbuf, recvcount * sizeofDatatype(recvtype));
    for (int i=0; i<nprocs; i++) {
      if (i != root)
	$mpi_collective_recv
	  ($mpi_pointer_add(recvbuf, i * recvcount, recvtype),
	   recvcount, recvtype, 
	   i, tag, comm, MPI_STATUS_IGNORE, routName);
    }
  } else { // non-root
    $mpi_collective_send(sendbuf, sendcount, sendtype, root, tag, comm);
  }
}

// Communicator functions...

$mpi_gcomm $mpi_gcomm_create($scope scope, int size) {
  $mpi_gcomm result;
  result.scope = scope;
  result.p2p = $gcomm_create(scope, size);
  result.col = $gcomm_create(scope, size);
  result.gbarrier = $gbarrier_create(scope, size);
  result.cmg = $cmon_g_create(scope, size);
  return result;
}

void $mpi_gcomm_destroy($mpi_gcomm gc) {
  /* This function will report errors for any messages remaining the
     $mpi_gcomm. Those messages are junk messages. */
  int numJunkRecord;
  int numJunkMsg;
  $message junkMsgs[]; // A CIVL-C sequence for junk messages.

  $seq_init(&junkMsgs, 0, NULL);
  numJunkMsg = $gcomm_destroy(gc.p2p, &junkMsgs);
  /* Informations of reporting junk messages in p2p communicator and
     collective communicator are different: */
  for(int i = 0; i < numJunkMsg; i++) {
    int src, dest, tag;

    src = $message_source(junkMsgs[i]);
    dest = $message_dest(junkMsgs[i]);
    tag = $message_tag(junkMsgs[i]);
    $assert($false,
	    "MPI message leak: There is a message from rank %d to rank %d with tag %d "
	    "has been sent but is never received in point-to-point communication.", 
	    src, dest, tag);
  }
  numJunkMsg = $gcomm_destroy(gc.col, &junkMsgs);
  for(int i = 0; i < numJunkMsg; i++) {
    int src, tag;
    char * routine;
    src = $message_source(junkMsgs[i]);
    tag = $message_tag(junkMsgs[i]);
    routine = $mpi_coroutine_name(tag);
    $assert($false,
	    "MPI message leak: There is a message sent by rank %d for collective routine %s"
	    " that is never received.", 
	    src, routine);
  }  
  $gbarrier_destroy(gc.gbarrier);
  $cmon_g_destroy(gc.cmg);
}

MPI_Comm $mpi_comm_create($scope scope, $mpi_gcomm gc, int rank) {
  MPI_Comm result = (MPI_Comm)$malloc(scope, sizeof(*result));
   // TODO: eventually get rid of gscope and make a reference to gc
  result->gscope = gc.scope;
  result->scope = scope;
  result->p2p = $comm_create(scope, gc.p2p, rank);
  result->col = $comm_create(scope, gc.col, rank);
  result->barrier = $barrier_create(scope, gc.gbarrier, rank);
  result->gcommIndex = 0;
  result->cm = $cmon_create(scope, gc.cmg, rank);
  return result;
}

void $mpi_comm_destroy(MPI_Comm comm, $mpi_state mpi_state) {
  if (comm->gcommIndex == 0)
    $assert(mpi_state == _MPI_FINALIZED, "Process terminates without "
	    "calling MPI_Finalize() first.");
  $comm_destroy(comm->p2p);
  $comm_destroy(comm->col);
  $barrier_destroy(comm->barrier);
  $cmon_destroy(comm->cm);
  $free(comm);
}

void $mpi_comm_dup($scope scope, MPI_Comm comm,
		   MPI_Comm * newcomm, char * routName) {
  int place = $comm_place(comm->col);
  $mpi_gcomm newgcomm;
  int idx;
  $scope CMPI_ROOT_SCOPE = $mpi_root_scope(comm);

  if(place == 0) {
    int size = $comm_size(comm->col);
    newgcomm = $mpi_gcomm_create(CMPI_ROOT_SCOPE, size);
    idx = $mpi_new_gcomm(CMPI_ROOT_SCOPE, newgcomm);
  }
  bcast(&idx, 1, MPI_INT, 0, COMMDUP_TAG, comm, routName);
  newgcomm = $mpi_get_gcomm(CMPI_ROOT_SCOPE, idx);
  (*newcomm) = $mpi_comm_create(scope, newgcomm, place);
  (*newcomm)->gcommIndex = idx;
  $barrier_call(comm->barrier);
  $gcomm_dup(comm->p2p, (*newcomm)->p2p);
  $gcomm_dup(comm->col, (*newcomm)->col);
  $barrier_call(comm->barrier);
}

$mpi_gcomm $mpi_comm_self_create($scope scope, MPI_Comm * mpi_comm_self) {
  $mpi_gcomm newgcomm = $mpi_gcomm_create(scope, /*size=*/1);
  *mpi_comm_self = $mpi_comm_create(scope, newgcomm, /*rank=*/0);
  return newgcomm;
}

void $mpi_comm_free(MPI_Comm *comm, $mpi_state mpi_state) {
  int place = $comm_place((*comm)->col);
  int size = $comm_size((*comm)->col);
  int buf[size];
  int gcommIndex = (*comm)->gcommIndex;
  $scope CMPI_ROOT_SCOPE = $mpi_root_scope(*comm);

  //TODO: gather here is just a ugly synchronization
  // Why ugly?  Change to 0-byte message.
  gather(&place, 1, MPI_INT, buf, 1, MPI_INT, 0, 
	 COMMFREE_TAG, (*comm), "MPI_Comm_free synchronization.");
  $mpi_comm_destroy(*comm, mpi_state);
  if (place == 0) {
    // can't we get this from the comm?
    $mpi_gcomm temp = $mpi_get_gcomm(CMPI_ROOT_SCOPE, gcommIndex);
    $mpi_gcomm_destroy(temp);
  }
}

$atomic_f $state_f $cmon $mpi_get_cmon(MPI_Comm comm) {
  return comm->cm;
}

$atomic_f $state_f $comm $mpi_get_p2p_channel(MPI_Comm comm) {
  return comm->p2p;
}

$atomic_f $state_f $comm $mpi_get_col_channel(MPI_Comm comm) {
  return comm->col;
}

$atomic_f $state_f int $mpi_comm_size(MPI_Comm comm) {
  return $comm_size(comm->p2p);
}

$atomic_f $state_f int $mpi_comm_place(MPI_Comm comm) {
  return $comm_place(comm->p2p);
}

$atomic_f $state_f $scope $mpi_root_scope(MPI_Comm comm) {
  return comm->gscope;
}

$atomic_f $state_f $scope $mpi_proc_scope(MPI_Comm comm) {
  return comm->scope;
}

// Point to point support functions...

void $mpi_send(const void *buf, int count, MPI_Datatype datatype, int dest,
	       int tag, MPI_Comm comm) {
  if (dest >= 0) {
    int size = count*sizeofDatatype(datatype);
    int place = $comm_place(comm->p2p);
    $elaborate(dest);
    $message out = $message_pack(place, dest, tag, buf, size);
    $comm_enqueue(comm->p2p, out);   
  }
}

void $mpi_recv(void *buf, int count, MPI_Datatype datatype, int source,
	       int tag, MPI_Comm comm, MPI_Status *status) {
  $assert(tag == MPI_ANY_TAG || tag >= 0,
	  "Illegal MPI message receive tag %d.\n", tag);
  if (source >= 0 || source == MPI_ANY_SOURCE) {
    int place = $comm_place(comm->p2p);
    $elaborate(source);
    $message in = $comm_dequeue(comm->p2p, source, tag);
    int size = count*sizeofDatatype(datatype);
    $message_unpack(in, buf, size);
    if (status != MPI_STATUS_IGNORE) {
      status->size = $message_size(in);
      status->MPI_SOURCE = $message_source(in);
      status->MPI_TAG = $message_tag(in);
      status->MPI_ERROR = 0;
    }
  }
}

// $mpi_isend, $mpi_irecv, $mpi_wait_send, $mpi_wait_recv: unimplemented

void $mpi_sendrecv(const void *sendbuf, int sendcount, MPI_Datatype sendtype,
		   int dest, int sendtag, void *recvbuf, int recvcount, 
		   MPI_Datatype recvtype, int source, int recvtag,
		   MPI_Comm comm, MPI_Status *status) {
  $assert(sendtag >= 0,
	  "MPI sendtag should be greater than or equal to zero");
  $assert(recvtag == MPI_ANY_TAG || recvtag >= 0,
	  "Illegal MPI message receive tag %d.\n", recvtag);
  if (dest >= 0 && (source >= 0 || source == MPI_ANY_SOURCE)) {
    $message out, in;
    int size = sendcount*sizeofDatatype(sendtype);
    int place = $comm_place(comm->p2p);

    out = $message_pack(place, dest, sendtag, sendbuf, size);
    $elaborate(source);
    $elaborate(dest);
    $choose {
      $when ($true) {
	$comm_enqueue(comm->p2p, out);
	in = $comm_dequeue(comm->p2p, source, recvtag);
      }
      $when ($false) {
        /* This $choose branch plays a trick which correctly
	   implements the sendrecv() semantically. Such a branch
	   ensures that there is no chance of potential deadlocks when
	   all processes do send then recv collectively. However,
	   effectively, this branch is no need and never will be
	   executed.  TODO: WTF??? */
	in = $comm_dequeue(comm->p2p, source, recvtag);
	$comm_enqueue(comm->p2p, out);
      }
    }
    size = recvcount*sizeofDatatype(recvtype);
    $message_unpack(in, recvbuf, size);
    if (status != MPI_STATUS_IGNORE) {
      status->size = $message_size(in);
      status->MPI_SOURCE = $message_source(in);
      status->MPI_TAG = $message_tag(in);
      status->MPI_ERROR = 0;
    }
  }
  else if (dest >= 0)
    $mpi_send(sendbuf, sendcount, sendtype, dest, sendtag, comm);
  else if (source >= 0 || source == MPI_ANY_SOURCE) 
    $mpi_recv(recvbuf, recvcount, recvtype, source, recvtag, comm, status);
}

// Collective support functions...

void $mpi_collective_send(const void *buf, int count, MPI_Datatype datatype,
			  int dest, int tag, MPI_Comm comm) {
  if (dest >= 0) {
    int size = count*sizeofDatatype(datatype);
    int place = $comm_place(comm->col);
    $message out = $mpi_convert_pack(place, buf, count, datatype, dest, tag);
    $elaborate(dest);
    $comm_enqueue(comm->col, out);   
  }
}

void $mpi_collective_recv(void *buf, int count, MPI_Datatype datatype, 
			  int source, int tag, MPI_Comm comm, 
			  MPI_Status * status, char * routName) {
  if (source >= 0 || source == MPI_ANY_SOURCE) {
    $elaborate(source);
    $message in = $comm_dequeue(comm->col, source, tag);
    $mpi_unpack_convert(in, buf, count, datatype);
    if (status != MPI_STATUS_IGNORE) {
      // TODO: unfortunately, for the special MPI pair types, the size
      // will be measured using sizeof the MPI special type, rather than
      // the user's original type.  There is no way to get the user's type
      // at this time.  Need a way to get the dynamic type of buf, and then
      // get the element type.
      status->size = $message_size(in);
      status->MPI_SOURCE = $message_source(in);
      status->MPI_TAG = tag;
      status->MPI_ERROR = 0;
    }
  }
}

// copy of the p2p version, modified for col
void $mpi_collective_sendrecv
(const void *sendbuf, int sendcount, MPI_Datatype sendtype,
 int dest, int sendtag, void *recvbuf, int recvcount, 
 MPI_Datatype recvtype, int source, int recvtag,
 MPI_Comm comm, MPI_Status *status)
{
  $assert(sendtag >= 0, "MPI sendtag should be greater than or equal to zero");
  $assert(recvtag == MPI_ANY_TAG || recvtag >= 0,
	  "Illegal MPI message receive tag %d.\n", recvtag);
  if (dest >= 0 && (source >= 0 || source == MPI_ANY_SOURCE)) {
    $message out, in;
    int size = sendcount*sizeofDatatype(sendtype);
    int place = $comm_place(comm->col);

    out = $message_pack(place, dest, sendtag, sendbuf, size);
    $elaborate(source);
    $elaborate(dest);
    $choose {
      $when ($true) {
	$comm_enqueue(comm->col, out);
	in = $comm_dequeue(comm->col, source, recvtag);
      }
      $when ($false) {
        /* This $choose branch plays a trick which correctly
	   implements the sendrecv() semantically. Such a branch
	   ensures that there is no chance of potential deadlocks when
	   all processes do send then recv collectively. However,
	   effectively, this branch is no need and never will be
	   executed.  TODO: WTF??? */
	in = $comm_dequeue(comm->col, source, recvtag);
	$comm_enqueue(comm->col, out);
      }
    }
    size = recvcount*sizeofDatatype(recvtype);
    $message_unpack(in, recvbuf, size);
    if (status != MPI_STATUS_IGNORE) {
      status->size = $message_size(in);
      status->MPI_SOURCE = $message_source(in);
      status->MPI_TAG = $message_tag(in);
      status->MPI_ERROR = 0;
    }
  }
  else if (dest >= 0)
    $mpi_send(sendbuf, sendcount, sendtype, dest, sendtag, comm);
  else if (source >= 0 || source == MPI_ANY_SOURCE) 
    $mpi_recv(recvbuf, recvcount, recvtype, source, recvtag, comm, status);
}

void $mpi_barrier(MPI_Comm comm) {
  $barrier_call(comm->barrier);
}

#endif
