#ifndef __CIVLC_BUNDLE__
#define __CIVLC_BUNDLE__
/* This file completes the definitions of some types and functions
 * for bundle, which are declared in bundle.cvh.
 */
#include<bundle.cvh>
#include<pointer.cvh>

$atomic_f void $bundle_unpack_apply($bundle data, void *buf, $operation op,
				    int count, void *result) {
  $assert(buf != result,
	  "Input pointer %p and output pointer %p shall not point to the same memory "
	  "location.", buf, result);
  if (count > 0) {
    size_t type_size = $bundle_size(data) / count;
    $bundle_unpack(data, result);
    for (int i = 0; i < count; i++) {
      void * operand0 = $pointer_add(result, i, type_size);
      void * operand1 = $pointer_add(buf, i, type_size);
      $apply(operand0, op, operand1, operand0);
    }
  }
}

#endif
