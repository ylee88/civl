#ifndef __CIVL_MPI__
#define __CIVL_MPI__

#include <bundle.cvh>
#include <civl-mpi.cvh>
#include <cmon.cvh>
#include <concurrency.cvh>
#include <mpi.h>
#include <pointer.cvh>
#include <seq.cvh>
#include <stdlib.h>
#include <string.h>

/* The state of MPI on this process: uninitialized, initialized, or
   finalized.  This will become a process local variable. */
$mpi_state _mpi_state=_MPI_UNINIT;

/* This variable is here just to create a unique pointer value
   MPI_IN_PLACE, declared in mpi.h */
extern const int MPI_IN_PLACE_SPOT = 0;

// Helper functions...

static void checkInit(void) {
  $assert(_mpi_state == _MPI_INIT,
	  "An MPI function was called when MPI was not initialized");
}

// Macro to apply a binary function element-wise:
#define BUF_APPLY_F(res, count, T, F, buf1, buf2)			\
  { T *_r = (T*)(res), *_b1 = (T*)(buf1), *_b2 = (T*)(buf2);		\
    for (int _i=0; _i<count; _i++) _r[_i] = F(_b1[_i], _b2[_i]);	\
  }

#define MAX(x,y) ((x)>=(y) ? (x) : (y))
#define MIN(x,y) ((x)<=(y) ? (x) : (y))
#define LAND(x,y) ((x)&&(y))
#define LOR(x,y) ((x)||(y))
#define LXOR(x,y) (!(x) != !(y))
#define BAND(x,y) ((x)&(y))
#define BOR(x,y) ((x)|(y))
#define BXOR(x,y) ((x)^(y))
#define ADD(x,y) ((x)+(y))
#define MUL(x,y) ((x)*(y))

_Bool isIntegerDatatype(MPI_Datatype dt) {
  switch (dt) {
  case MPI_SHORT:
  case MPI_UNSIGNED_SHORT:
  case MPI_INT:
  case MPI_INT16_T:
  case MPI_INT32_T:
  case MPI_INT64_T:
  case MPI_INT8_T:
  case MPI_INTEGER:
  case MPI_INTEGER1:
  case MPI_INTEGER16:
  case MPI_INTEGER2:
  case MPI_INTEGER4:
  case MPI_INTEGER8:
  case MPI_UNSIGNED:
  case MPI_LONG:
  case MPI_UNSIGNED_LONG:
  case MPI_LONG_LONG_INT:
  case MPI_UNSIGNED_LONG_LONG:
  case MPI_LONG_LONG:
  case MPI_LB:
  case MPI_UB:
  case MPI_UINT16_T:
  case MPI_UINT32_T:
  case MPI_UINT64_T:
  case MPI_UINT8_T:
  case MPI_AINT:
  case MPI_OFFSET:
    return $true;
  default:
    return $false;  
  }
}

_Bool isRealDatatype(MPI_Datatype dt) {
  switch (dt) {
  case MPI_FLOAT:
  case MPI_DOUBLE:
  case MPI_LONG_DOUBLE:
  case MPI_REAL:
  case MPI_REAL16:
  case MPI_REAL2:
  case MPI_REAL4:
  case MPI_REAL8:
    return $true;
  default:
    return $false;
  }
}

// The following macros support MPI reductions operations...

#define APPLY_OP(result, count, dt, op, buf1, buf2) {			\
    if (isRealDatatype(dt))						\
      BUF_APPLY_F(result, count, $real, op, buf1, buf2)	         	\
    else if (isIntegerDatatype(dt))					\
      BUF_APPLY_F(result, count, int, op, buf1, buf2)			\
    else {								\
      switch (dt) {							\
      case MPI_C_COMPLEX:						\
      case MPI_C_FLOAT_COMPLEX:						\
	BUF_APPLY_F(result, count, float _Complex, op, buf1, buf2)	\
	break;								\
      case MPI_C_DOUBLE_COMPLEX:					\
	BUF_APPLY_F(result, count, double _Complex, op, buf1, buf2)	\
	break;								\
      case MPI_C_LONG_DOUBLE_COMPLEX:					\
	BUF_APPLY_F(result, count, long double _Complex, op, buf1, buf2) \
	break;								\
      default:								\
        $assert($false,							\
		"Cannot apply operator to datatype %s", dt);		\
      }									\
    }									\
  }

#define APPLY_OP_REAL_INT(result, count, dt, op, buf1, buf2) {		\
    if (isRealDatatype(dt))						\
      BUF_APPLY_F(result, count, $real, op, buf1, buf2)	         	\
    else if (isIntegerDatatype(dt))					\
      BUF_APPLY_F(result, count, int, op, buf1, buf2)			\
    else								\
      $assert($false, "Cannot apply operator to datatype");		\
  }

#define APPLY_OP_INT(result, count, dt, op, buf1, buf2)			\
  BUF_APPLY_F(result, count, int, op, buf1, buf2)

// Support for MPI_MINLOC and MPI_MAXLOC. CMP is < or > ...

#define DO_MLOC(T1, T2, result, count, CMP, buf1, buf2) {	\
  struct _PAIR {T1 val; T2 rank; };				\
  struct _PAIR *r = (struct _PAIR *)result,			\
    *b1 = (struct _PAIR *)buf1, *b2 = (struct _PAIR *)buf2;	\
  for (int i=0; i<count; i++) {					\
    T1 val1 = b1[i].val, val2 = b2[i].val;			\
    T2 rank1 = b1[i].rank, rank2 = b2[i].rank;			\
    if (val1 CMP val2) {					\
      r[i].val = val1;						\
      r[i].rank = rank1;					\
    } else if (val1 == val2) {					\
      r[i].val = val1;						\
      r[i].rank = MIN(rank1, rank2);				\
    } else {							\
      r[i].val = val2;						\
      r[i].rank = rank2;					\
    }								\
  }								\
}


#define APPLY_MLOC(result, count, dt, CMP, buf1, buf2) 	        \
  switch (dt) {						        \
  case MPI_2INT:					        \
  case MPI_2INTEGER:					        \
  case MPI_SHORT_INT:					        \
  case MPI_LONG_INT:					        \
    DO_MLOC(int, int, result, count, CMP, buf1, buf2)		\
    break;                                                      \
  case MPI_FLOAT_INT:				                \
  case MPI_DOUBLE_INT:						\
  case MPI_LONG_DOUBLE_INT:					\
    DO_MLOC($real, int, result, count, CMP, buf1, buf2)		\
    break;							\
  case MPI_2REAL:						\
  case MPI_2DOUBLE_PRECISION:					\
    DO_MLOC($real, $real, result, count, CMP, buf1, buf2)	\
    break;							\
  default:							\
    $assert($false, "Wrong datatype for MINLOC or MAXLOC");	\
  }


/* Applies binary operator element-wise to buf1 and buf2, storing
   results in buffer result.  */
void apply(void * result, int count, MPI_Datatype dt, MPI_Op op,
	   void * buf1, void * buf2) {
  // TODO: user-defined reduction operators
  switch (op) {
  case MPI_SUM:
    APPLY_OP(result, count, dt, ADD, buf1, buf2)
    break;
  case MPI_PROD:
    APPLY_OP(result, count, dt, MUL, buf1, buf2)
    break;
  case MPI_MAX:
    APPLY_OP_REAL_INT(result, count, dt, MAX, buf1, buf2)
    break;
  case MPI_MIN:
    APPLY_OP_REAL_INT(result, count, dt, MIN, buf1, buf2)
    break;
  case MPI_LAND:
    APPLY_OP_INT(result, count, dt, LAND, buf1, buf2)
    break;
  case MPI_LOR:
    APPLY_OP_INT(result, count, dt, LOR, buf1, buf2)
    break;
  case MPI_LXOR:
    APPLY_OP_INT(result, count, dt, LXOR, buf1, buf2)
    break;
  case MPI_BAND:
    APPLY_OP_INT(result, count, dt, BAND, buf1, buf2)
    break;
  case MPI_BOR:
    APPLY_OP_INT(result, count, dt, BOR, buf1, buf2)
    break;
  case MPI_BXOR:
    APPLY_OP_INT(result, count, dt, BXOR, buf1, buf2)
    break;
  case MPI_MINLOC:
    APPLY_MLOC(result, count, dt, <, buf1, buf2)
    break;
  case MPI_MAXLOC:
    APPLY_MLOC(result, count, dt, >, buf1, buf2)
    break;
  default:
    $assert($false, "Unknown reduction operator: %s", op);
  } // end of switch (op)
} // end of function apply


// Implementations of mpi.h functions ...

int $mpi_init(void) {
  $assert(_mpi_state == _MPI_UNINIT, "Process can only call MPI_Init() once.");
  _mpi_state = _MPI_INIT;
  return 0;
}

int MPI_Type_size(MPI_Datatype datatype, int *size) {
  checkInit();
  *size = sizeofDatatype(datatype);
  return 0;
}

int MPI_Finalize(void) {
  checkInit();
  _mpi_state = _MPI_FINALIZED;
  return 0;
}

double MPI_Wtime() {
  checkInit();
  int CMPI_time_count = $next_time_count();
  double result = $mpi_time(CMPI_time_count);
  if (CMPI_time_count > 0) {
    $assume(result > $mpi_time(CMPI_time_count-1));
  } else {
    $assume(result > 0);
  }
  return result;
}

int MPI_Comm_size(MPI_Comm comm, int *size) {
  checkInit();
  *size = $mpi_comm_size(comm);
  return 0;
}

int MPI_Comm_rank(MPI_Comm comm, int *rank) {
  checkInit();
  *rank = $mpi_comm_place(comm);
  return 0;
}

int MPI_Send(const void *buf, int count, MPI_Datatype datatype, int dest,
	     int tag, MPI_Comm comm) {
  checkInit();
#ifdef _MPI_NON_BLOCKING
  MPI_Request request;
  $mpi_isend(buf, count, datatype, dest, tag, comm, &request);
  $mpi_wait(&request, MPI_STATUS_IGNORE);
#elif defined(_MPI_BLOCKING)
  $mpi_send(buf, count, datatype, dest, tag, comm);
#endif
  return 0;
}

int MPI_Isend(void *buf, int count, MPI_Datatype datatype, int dest,
	      int tag, MPI_Comm comm, MPI_Request * request) {
  checkInit();
#ifdef _MPI_NON_BLOCKING
  $mpi_isend(buf, count, datatype, dest, tag, comm, request);
#elif defined(_MPI_BLOCKING)
  $assert(0, "MPI_Isend is not supported in the MPI blocking implementation.");
#endif
  return 0;
}

int MPI_Recv(void *buf, int count, MPI_Datatype datatype, int source,
	     int tag, MPI_Comm comm, MPI_Status *status) {
  checkInit();
#ifdef _MPI_NON_BLOCKING
  MPI_Request request;
  $mpi_irecv(buf, count, datatype, source, tag, comm, &request);
  $mpi_wait(&request, status);
#elif defined(_MPI_BLOCKING)
  $mpi_recv(buf, count, datatype, source, tag, comm, status);
#endif
  return 0;
}

int MPI_Irecv(void *buf, int count, MPI_Datatype datatype, int source,
	      int tag, MPI_Comm comm, MPI_Request * request) {
  checkInit();
#ifdef _MPI_NON_BLOCKING
  $mpi_irecv(buf, count, datatype, source, tag, comm, request);
#elif  defined(_MPI_BLOCKING)
  $assert(0, "MPI_Irecv is not supported in the MPI blocking implementation.");
#endif
  return 0;
}

int MPI_Wait(MPI_Request * request, MPI_Status * status) {
  checkInit();
#ifdef _MPI_NON_BLOCKING
  $mpi_wait(request, status);
#elif defined(_MPI_BLOCKING)
  $assert(0, "MPI_Wait is not supported in the MPI blocking implementation.");
#endif
  return 0;
}

int MPI_Waitall(int count, MPI_Request array_of_requests[],
		MPI_Status array_of_statuses[]) {
  checkInit();
#ifdef _MPI_NON_BLOCKING
  $for (int i : 0 .. count-1) {
    MPI_Status * status = array_of_statuses == MPI_STATUSES_IGNORE ?
      MPI_STATUS_IGNORE : array_of_statuses + i;
    MPI_Request * req = array_of_requests + i;
    $mpi_wait(req, status);
  }
#elif defined(_MPI_BLOCKING)
  $assert(0, "MPI_Waitall is not supported in the MPI blocking implementation.");
#endif
  return 0;
}

int MPI_Test(MPI_Request *request, int *flag, MPI_Status *status) {
  checkInit();
#ifdef _MPI_NON_BLOCKING
  if (*request == MPI_REQUEST_NULL) {
    *flag = 1;
    return 0;
  }
  $choose {
    $when ($true) {
      $mpi_wait(request, status);
      *flag = 1;
    }
    $when ($true)
      *flag = 0;
  }
#elif defined(_MPI_BLOCKING)
  $assert(0, "MPI_Test is not supported in the MPI blocking implementation.");
#endif
  return 0;
}

int MPI_Request_free(MPI_Request * request) {
  checkInit();
  // The standard does not say this function accepts MPI_REQUEST_NULL
#ifdef _MPI_NON_BLOCKING
  $free(*request);
  *request = MPI_REQUEST_NULL;
#elif defined(_MPI_BLOCKING)
  $assert(0, "MPI_Request_free is not supported in the MPI blocking implementation.");
#endif
  return 0;
}

int MPI_Get_count(MPI_Status *status, MPI_Datatype datatype, int *count) {
  checkInit();
  *count = status->size/sizeofDatatype(datatype);
  return 0;
}

int MPI_Get_processor_name(char * name, int * resultlen) {
  checkInit();
  $abstract int MPI_GET_PROCESSOR_NAME(char *, int *);
  return MPI_GET_PROCESSOR_NAME(name, resultlen);
}

int MPI_Sendrecv(void *sendbuf, int sendcount, MPI_Datatype sendtype,
		 int dest, int sendtag,
		 void *recvbuf, int recvcount, MPI_Datatype recvtype,
		 int source, int recvtag,
		 MPI_Comm comm, MPI_Status *status) {
  checkInit();
  //$mpi_check_buffer(sendbuf, sendcount, sendtype);
  // not correct for checking potential deadlock...rewrite:
  $mpi_sendrecv(sendbuf, sendcount, sendtype, dest, sendtag, recvbuf, recvcount,
		recvtype, source, recvtag, comm, status);
  return 0;
}

/******************************** Collective ***********************************/

// Collective helper functions. These do not do any checking of
// arguments.  They also take a tag to use for the underlying p2p
// communications on the collective comm.

/* Broadcast helper function that uses any specified message tag */
static void bcast
(void *buf, int count, MPI_Datatype datatype, int root,
 int tag, MPI_Comm comm, char * routName)
{
  int rank = $mpi_comm_place(comm);
  if (rank == root) {
    int nprocs = $mpi_comm_size(comm);
    for (int i=0; i<nprocs; i++)
      if (i != root)
	$mpi_collective_send(buf, count, datatype, i, tag, comm);
  } else
    $mpi_collective_recv(buf, count, datatype, root, tag, comm,
			 MPI_STATUS_IGNORE, routName);
}

static void gather
(const void* sendbuf, int sendcount, MPI_Datatype sendtype, 
 void* recvbuf, int recvcount, MPI_Datatype recvtype, 
 int root, int tag, MPI_Comm comm, char * routName)
{
  int rank = $mpi_comm_place(comm), nprocs = $mpi_comm_size(comm);
  if (rank == root) {
    if (sendbuf != MPI_IN_PLACE) {
      $mpi_memcpy($mpi_pointer_add(recvbuf, root * recvcount, recvtype),
		  sendbuf, recvcount, recvtype);
    }
    for (int i=0; i<nprocs; i++) {
      if (i != root)
	$mpi_collective_recv
	  ($mpi_pointer_add(recvbuf, i * recvcount, recvtype),
	   recvcount, recvtype, 
	   i, tag, comm, MPI_STATUS_IGNORE, routName);
    }
  } else { // non-root
    $mpi_collective_send(sendbuf, sendcount, sendtype, root, tag, comm);
  }
}

/* Gatherv helper that uses any tag */
static void gatherv
(const void* sendbuf, int sendcount, MPI_Datatype sendtype,
 void* recvbuf, const int recvcounts[], const int displs[],
 MPI_Datatype recvtype, int root, int tag, 
 MPI_Comm comm, char * routName)
{
  int rank = $mpi_comm_place(comm), nprocs = $mpi_comm_size(comm);
  if (rank == root) {
    if (sendbuf != MPI_IN_PLACE) {
      $mpi_memcpy($mpi_pointer_add(recvbuf, displs[rank], recvtype),
		  sendbuf, sendcount, recvtype);
    }
    for (int i=0; i<nprocs; i++) {
      if (i != root)
	$mpi_collective_recv
	  ($mpi_pointer_add(recvbuf, displs[i], recvtype), recvcounts[i], 
	   recvtype, i, tag, comm, MPI_STATUS_IGNORE, routName);
    }
  } else {
    $mpi_collective_send(sendbuf, sendcount, sendtype, root, tag, comm);
  }
}

static void scatter
(const void* sendbuf, int sendcount, MPI_Datatype sendtype, 
 void* recvbuf, int recvcount, MPI_Datatype recvtype,
 int root, int tag, MPI_Comm comm, char * routName)
{
  int rank = $mpi_comm_place(comm), nprocs = $mpi_comm_size(comm);
  if (rank == root) {
    if (recvbuf != MPI_IN_PLACE) {
      $mpi_memcpy(recvbuf, $mpi_pointer_add(sendbuf, root*recvcount, sendtype),
		  recvcount, recvtype);
    }
    int offset;
    for (int i=0; i<nprocs; i++) {
      if (i != root)
	$mpi_collective_send
	  ($mpi_pointer_add(sendbuf, i * sendcount, sendtype),
	   sendcount, sendtype, i, tag, comm);
    }
  } else { // non-root
    $mpi_collective_recv(recvbuf, recvcount, recvtype, root,
			 tag, comm, MPI_STATUS_IGNORE, routName);
  }
}

static void scatterv
(const void* sendbuf, const int sendcounts[],
 const int displs[], MPI_Datatype sendtype,
 void * recvbuf, int recvcount, MPI_Datatype recvtype,
 int root, int tag, MPI_Comm comm, char * routName)
{
  int rank = $mpi_comm_place(comm), nprocs = $mpi_comm_size(comm);
  if (rank == root) {
    if (recvbuf != MPI_IN_PLACE) {
      $mpi_memcpy(recvbuf, $mpi_pointer_add(sendbuf, displs[root], sendtype),
		  recvcount, recvtype);
    }
    for (int i=0; i<nprocs; i++) {
      if (i != root)
	$mpi_collective_send
	  ($mpi_pointer_add(sendbuf, displs[i], sendtype),
	   sendcounts[i], sendtype, i, tag, comm);
    }
  } else { // non-root
    $mpi_collective_recv(recvbuf, recvcount, recvtype, 
			 root, tag, comm, MPI_STATUS_IGNORE, routName);
  }
}

/* Reduction helper function that uses any specified message tag */
static void reduce
(const void* sendbuf, void* recvbuf, int count,
 MPI_Datatype datatype, MPI_Op op, int root, int tag,
 MPI_Comm comm, char * routName)
{
  int rank = $mpi_comm_place(comm);
  if (rank != root)
    $mpi_collective_send(sendbuf, count, datatype, root, tag, comm);
  else {
    int nprocs = $mpi_comm_size(comm);
    int elt_size = sizeofDatatype(datatype);
    void * tmpbuf = $mpi_malloc($mpi_proc_scope(comm), count, datatype);
    if (sendbuf != MPI_IN_PLACE) {
      $mpi_memcpy(recvbuf, sendbuf, count, datatype);
    }
    for (int i=0; i<nprocs; i++) {
      if (i != root) {
	$mpi_collective_recv(tmpbuf, count, datatype, i, tag, comm,
			     MPI_STATUS_IGNORE, "MPI_Reduce()");
	apply(recvbuf, count, datatype, op, recvbuf, tmpbuf);
      }
    }
    $free(tmpbuf);
  }
}

// Implementations of the (blocking) MPI collectives...

int MPI_Barrier(MPI_Comm comm) {
  checkInit();
  $cmon_check_0($mpi_get_cmon(comm), BARRIER_TAG);
  $mpi_barrier(comm);
  return 0;
}

int MPI_Bcast(void *buf, int count, MPI_Datatype datatype, int root,
	      MPI_Comm comm) {
  checkInit();
  $cmon_check_1($mpi_get_cmon(comm), BCAST_TAG, $false,
		($mpi_tsig){ .count=count, .type=datatype },
		_NO_OP, root);
  //  if ($mpi_comm_place(comm) == root)
  //    $mpi_check_buffer(buf, count, datatype);
  bcast(buf, count, datatype, root, BCAST_TAG, comm, "MPI_Bcast()");
  return 0;
}

int MPI_Gather(const void* sendbuf, int sendcount, MPI_Datatype sendtype,
	       void* recvbuf, int recvcount, MPI_Datatype recvtype,
	       int root, MPI_Comm comm) {
  checkInit();
  $cmon_check_1_1($mpi_get_cmon(comm), GATHER_TAG, sendbuf==MPI_IN_PLACE,
		  ($mpi_tsig){ .count=sendcount, .type=sendtype },
		  ($mpi_tsig){ .count=recvcount, .type=recvtype },
		  _NO_OP, root);
  //  if (sendbuf != MPI_IN_PLACE)
  //    $mpi_check_buffer(sendbuf, sendcount, sendtype);
  gather(sendbuf, sendcount, sendtype, recvbuf, recvcount, recvtype,
	 root, GATHER_TAG, comm, "MPI_Gather()");
  return 0;
}

/* MPI_Gatherv extends the functionality of MPI_Gather by allowing a
   varying count of data to be sent to root process, since recvcounts
   is now an array.*/
int MPI_Gatherv(const void * sendbuf, int sendcount, MPI_Datatype sendtype,
		void * recvbuf, const int recvcounts[], const int displs[],
		MPI_Datatype recvtype, int root, MPI_Comm comm) {
  checkInit();
  int nprocs = $mpi_comm_size(comm), rank = $mpi_comm_place(comm);
  $mpi_tsig * sigs2 = NULL;
  if (rank == root)
    sigs2 = ($mpi_tsig[nprocs]) $lambda (int i)
      ($mpi_tsig){ .count = recvcounts[i], .type=recvtype };
  $cmon_check_1_n
    ($mpi_get_cmon(comm), GATHERV_TAG, sendbuf==MPI_IN_PLACE,
     ($mpi_tsig){ .count=sendcount, .type=sendtype },
     sigs2, _NO_OP, root);
  //  if (sendbuf != MPI_IN_PLACE)
  //    $mpi_check_buffer(sendbuf, sendcount, sendtype);
  gatherv(sendbuf, sendcount, sendtype, recvbuf, recvcounts, displs,
	  recvtype, root, GATHERV_TAG, comm, "MPI_Gatherv()");
  return 0;
}

int MPI_Scatter(const void* sendbuf, int sendcount, MPI_Datatype sendtype,
		void* recvbuf, int recvcount, MPI_Datatype recvtype, int root,
		MPI_Comm comm) {
  checkInit();
  $cmon_check_1_1($mpi_get_cmon(comm), SCATTER_TAG, recvbuf==MPI_IN_PLACE,
		  ($mpi_tsig){ .count=sendcount, .type=sendtype },
		  ($mpi_tsig){ .count=recvcount, .type=recvtype },
		  _NO_OP, root);
  //  if ($mpi_comm_place(comm) == root)
  //    $mpi_check_buffer(sendbuf, sendcount, sendtype);
  scatter(sendbuf, sendcount, sendtype, recvbuf, recvcount, recvtype,
	  root, SCATTER_TAG, comm, "MPI_Scatter()");
  return 0;
}

/* MPI_Scatterv extends the functionality of MPI_Scatter by allowing a
   varying count of data to be sent to each process, since sendcounts
   is now an array.*/
int MPI_Scatterv(const void * sendbuf, const int sendcounts[], const
		 int displs[], MPI_Datatype sendtype, void * recvbuf,
		 int recvcount, MPI_Datatype recvtype, int root, MPI_Comm comm) {
  checkInit();
  int nprocs = $mpi_comm_size(comm), rank = $mpi_comm_place(comm);
  $mpi_tsig * sigs2 = NULL;
  if (rank == root)
    sigs2 = ($mpi_tsig[nprocs]) $lambda (int i)
      ($mpi_tsig){ .count = sendcounts[i], .type=sendtype };
  $cmon_check_1_n
    ($mpi_get_cmon(comm), SCATTERV_TAG, recvbuf==MPI_IN_PLACE,
     ($mpi_tsig){ .count=recvcount, .type=recvtype },
     sigs2, _NO_OP, root);
  scatterv(sendbuf, sendcounts, displs, sendtype, recvbuf,
	   recvcount, recvtype, root, SCATTERV_TAG, comm,
	   "MPI_Scatterv()");
  return 0;
}

/* Implement by gather to root=0, then bcast.  (This is more efficient
   than the description in the MPI Standard, which executes nprocs
   gathers.)  Note: if a proc uses inplace, then data is in recv
   buffer.  For non-root, the gather must therefore use recv buffer
   for send buffer.  For root, no change is necessary. */
int MPI_Allgather(const void * sendbuf, int sendcount, MPI_Datatype sendtype,
                  void * recvbuf, int recvcount, MPI_Datatype recvtype,
                  MPI_Comm comm) {
  checkInit();
  $cmon_check_1_1($mpi_get_cmon(comm), ALLGATHER_TAG, sendbuf==MPI_IN_PLACE,
		  ($mpi_tsig){ .count=sendcount, .type=sendtype },
		  ($mpi_tsig){ .count=recvcount, .type=recvtype },
		  _NO_OP, -1);  
  int nprocs = $mpi_comm_size(comm), rank = $mpi_comm_place(comm);
  //  if (sendbuf != MPI_IN_PLACE)
  //    $mpi_check_buffer(sendbuf, sendcount, sendtype);
  if (rank == 0 || sendbuf != MPI_IN_PLACE)
    gather(sendbuf, sendcount, sendtype, recvbuf, recvcount, recvtype,
	   0, ALLGATHER_TAG, comm, "MPI_Allgather()");
  else
    gather($mpi_pointer_add(recvbuf, rank*recvcount, recvtype),
	   recvcount, recvtype, NULL, 0, MPI_DATATYPE_NULL,
	   0, ALLGATHER_TAG, comm, "MPI_Allgather()");
  bcast(recvbuf, recvcount*nprocs, recvtype, 0, ALLGATHER_TAG, comm,
	"MPI_Allgather()");
  return 0;
}

/* Not as easy as gather to root and bcast, because displs[] can
   be different on every proc.  Easier to follow the MPI Standard's
   spec. */
int MPI_Allgatherv(const void * sendbuf, int sendcount,
		   MPI_Datatype sendtype, void * recvbuf,
		   const int recvcounts[], const int displs[],
		   MPI_Datatype recvtype, MPI_Comm comm) {
  int nprocs = $mpi_comm_size(comm);
  checkInit();
  $cmon_check_1_n($mpi_get_cmon(comm), ALLGATHERV_TAG, sendbuf==MPI_IN_PLACE,
		  ($mpi_tsig){ .count=sendcount, .type=sendtype },
		  (($mpi_tsig[nprocs])$lambda (int i)
		   ($mpi_tsig){ .count=recvcounts[i], .type=recvtype }),
		  _NO_OP, -1);
  //  if (sendbuf != MPI_IN_PLACE)
  //    $mpi_check_buffer(sendbuf, sendcount, sendtype);
  for (int i=0; i<nprocs; i++)
    gatherv(sendbuf, sendcount, sendtype, recvbuf, recvcounts, displs,
	    recvtype, i, ALLGATHERV_TAG, comm, "MPI_Allgatherv()");
  return 0;
}

/* Implementation: nprocs scatters, with root=0,1,...,nprocs-1.
 */
int MPI_Alltoall(const void *sendbuf, int sendcount, MPI_Datatype sendtype,
                 void *recvbuf, int recvcount, MPI_Datatype recvtype,
                 MPI_Comm comm) {
  int nprocs = $mpi_comm_size(comm), rank = $mpi_comm_place(comm);
  _Bool inplace = sendbuf == MPI_IN_PLACE;
  checkInit();
  $cmon_check_1_1($mpi_get_cmon(comm), ALLTOALL_TAG, inplace,
		  ($mpi_tsig){ .count=sendcount, .type=sendtype },
		  ($mpi_tsig){ .count=recvcount, .type=recvtype },
		  _NO_OP, -1);
  //  if (inplace)
  //    $mpi_check_buffer(sendbuf, sendcount * nprocs, sendtype);
  //  else
  //    $mpi_check_buffer(recvbuf, recvcount * nprocs, recvtype);
  void * sbuf;
  int scount;
  MPI_Datatype stype;
  if (inplace) {
    sbuf = $mpi_malloc($mpi_proc_scope(comm), recvcount, recvtype);
    scount = recvcount;
    stype = recvtype;
    $mpi_memcpy(sbuf, recvbuf, scount, stype);
  } else {
    sbuf = (void*)sendbuf;
    scount = sendcount;
    stype = sendtype;
  }
  for (int i=0; i<nprocs; i++) {
    void * rbuf = $mpi_pointer_add(recvbuf, i*recvcount, recvtype);
    scatter(sbuf, scount, stype, rbuf, recvcount, recvtype,
	    i, ALLTOALL_TAG, comm, "MPI_Alltoall()");
  }
  if (inplace) $free(sbuf);
  return 0;
}

int MPI_Alltoallv
(const void* sendbuf, const int sendcounts[],
 const int sdispls[], MPI_Datatype sendtype, void* recvbuf,
 const int recvcounts[], const int rdispls[], MPI_Datatype recvtype,
 MPI_Comm comm) {
  int nprocs = $mpi_comm_size(comm), rank = $mpi_comm_place(comm);
  _Bool inplace = sendbuf == MPI_IN_PLACE;
  checkInit();
  $cmon_check_n_n($mpi_get_cmon(comm), ALLTOALLV_TAG, inplace,
		  (($mpi_tsig[nprocs])$lambda (int i)
		   ($mpi_tsig){ .count=sendcounts[i], .type=sendtype }),
		  (($mpi_tsig[nprocs])$lambda (int i)
		   ($mpi_tsig){ .count=recvcounts[i], .type=recvtype }));
  void *sbuf;
  const int * scounts;
  int * sdisps;
  MPI_Datatype stype;
  if (inplace) {
    scounts = recvcounts;
    stype = recvtype;
    sdisps = (int*)$malloc($mpi_proc_scope(comm), nprocs*sizeof(int));
    int scountSum = 0;
    for (int i=0; i<nprocs; i++) {
      sdisps[i] = scountSum;
      scountSum += scounts[i];
    }
    sbuf = $mpi_malloc($mpi_proc_scope(comm), scountSum, stype);
    int dsz = sizeofDatatype(stype);
    for (int i=0; i<nprocs; i++) {
      $mpi_memcpy($mpi_pointer_add(sbuf, sdisps[i], stype),
		  $mpi_pointer_add(recvbuf, rdispls[i], stype),
		  scounts[i], stype);
    }
  } else {
    scounts = sendcounts;
    stype = sendtype;
    sdisps = (int*)sdispls;
    sbuf = (void*)sendbuf;
  }
  for (int i = 0; i < nprocs; i++)
    scatterv(sbuf, scounts, sdisps, stype,
	     $mpi_pointer_add(recvbuf, rdispls[i], recvtype),
	     recvcounts[i], recvtype, i,
	     ALLTOALLV_TAG, comm, "MPI_Alltoallv()");
  if (inplace) {
    $free(sbuf);
    $free(sdisps);
  }
  return 0;
}

/* Note sdispls and rdispls are measured in bytes.
   Every process will do a send-recv exchange with all other processes.
   This is deadlock-free because there is a linearization (global order)
   on the exchange pairs: {0,1}, {0,2}, ..., {0,n-1}, {1,2}, ..., {1,n-1},
   ..., {n-2,n-1}.  Every process respects this global order.
 */
int MPI_Alltoallw(const void* sendbuf, const int sendcounts[], const int sdispls[],
		  const MPI_Datatype sendtypes[], void* recvbuf,
		  const int recvcounts[], const int rdispls[],
		  const MPI_Datatype recvtypes[], MPI_Comm comm) {
  int nprocs = $mpi_comm_size(comm), rank = $mpi_comm_place(comm);
  _Bool inplace = sendbuf==MPI_IN_PLACE;
  checkInit();
  $cmon_check_n_n($mpi_get_cmon(comm), ALLTOALLV_TAG, inplace,
		  (($mpi_tsig[nprocs])$lambda (int i)
		   ($mpi_tsig){ .count=sendcounts[i], .type=sendtypes[i] }),
		  (($mpi_tsig[nprocs])$lambda (int i)
		   ($mpi_tsig){ .count=recvcounts[i], .type=recvtypes[i] }));
  for (int i=0; i<nprocs; i++) {
    // exchange with proc i
    // beginning of recv buffer is (char*)recbuf+rdispls[i].
    // while this is correct, the pointer_add implementation needs to be improved
    // to make it work...
    void * rbuf = $pointer_add(recvbuf, rdispls[i], 1),
      * sbuf = $pointer_add(sendbuf, sdispls[i], 1);
    if (i == rank) {
      if (!inplace) {
	$mpi_memcpy(rbuf, sbuf, sendcounts[i], sendtypes[i]);
      }
    } else {
      int scount;
      MPI_Datatype stype;
      if (inplace) {
	scount = recvcounts[i];
	stype = recvtypes[i];
	sbuf = $mpi_malloc($mpi_proc_scope(comm), scount, stype);
	$mpi_memcpy(sbuf, rbuf, scount, stype);
      } else {
	scount = sendcounts[i];
	stype = sendtypes[i];
      }
      $mpi_collective_sendrecv
	(sbuf, scount, stype, i, ALLTOALLW_TAG,
	 rbuf, recvcounts[i], recvtypes[i], i, ALLTOALLW_TAG,
	 comm, MPI_STATUS_IGNORE);
      if (inplace) $free(sbuf);	
    }
  }
  return 0;
}

/* Reduces values on all processes to a single value */
int MPI_Reduce(const void* sendbuf, void* recvbuf, int count,
	       MPI_Datatype datatype, MPI_Op op, int root,
	       MPI_Comm comm) {
  checkInit();
  $cmon_check_1($mpi_get_cmon(comm), REDUCE_TAG, $false,
		($mpi_tsig){.count=count, .type=datatype},
		op, root);
  //  $mpi_check_buffer(sendbuf, count, datatype);
  $assert(0 <= op && op <= 13, "Unknown MPI reduction operation");
  // refer to op.h & mpi.h in ABC/src/include for how MPI_Op is defined
  reduce(sendbuf, recvbuf, count, datatype, op, root, REDUCE_TAG, comm,
	 "MPI_Reduce()");
  return 0;
}

/* Combines values from all processes and distributes the result back
   to all processes. default root is 0 */
int MPI_Allreduce(const void* sendbuf, void* recvbuf, int count,
		  MPI_Datatype datatype, MPI_Op op, MPI_Comm comm) {
  checkInit();
  $cmon_check_1($mpi_get_cmon(comm), ALLREDUCE_TAG, $false,
		($mpi_tsig){.count=count, .type=datatype},
		op, -1);
  int root = 0;
  MPI_Status status;
  //  $mpi_check_buffer(sendbuf, count, datatype);
  $assert(0 <= op && op <= 13, "unknown MPI reduce operation");
  // refer to op.h & mpi.h in ABC/src/include for how MPI_Op is defined
  reduce(sendbuf, recvbuf, count, datatype, op, root, ALLREDUCE_TAG, comm,
	 "MPI_Allreduce()");
  bcast(recvbuf, count, datatype, root, ALLREDUCE_TAG, comm,
	"MPI_Allreduce()");
  return 0;
}

int MPI_Reduce_local(const void *inbuf, void *inoutbuf, int count,
                     MPI_Datatype datatype, MPI_Op op) {
  checkInit();
  //  $mpi_check_buffer(inbuf, count, datatype);
  //  $mpi_check_buffer(inoutbuf, count, datatype);
  apply(inoutbuf, count, datatype, op, (void*)inbuf, inoutbuf);
  return 0;
}

/* Implementation: reduce to proc 0, then scatter. */
int MPI_Reduce_scatter_block
(const void *sendbuf, void *recvbuf, int recvcount,
 MPI_Datatype datatype, MPI_Op op, MPI_Comm comm) {
  int nprocs = $mpi_comm_size(comm), rank = $mpi_comm_place(comm);
  _Bool inplace = sendbuf == MPI_IN_PLACE;
  checkInit();
  $cmon_check_1($mpi_get_cmon(comm), REDUCE_SCATTER_BLOCK_TAG, inplace,
		($mpi_tsig){.count=recvcount, .type=datatype},
		op, -1);
  void * tmpbuf = rank == 0 ? $mpi_malloc($mpi_proc_scope(comm), recvcount*nprocs,  datatype) : NULL;
  const void * sbuf = inplace ? recvbuf : sendbuf;
  reduce(sbuf, tmpbuf, recvcount*nprocs,
	 datatype, op, 0, REDUCE_SCATTER_BLOCK_TAG,
	 comm, "MPI_Reduce_scatter_block()");
  scatter(tmpbuf, recvcount, datatype, recvbuf, recvcount, datatype,
	  0, REDUCE_SCATTER_BLOCK_TAG, comm, "MPI_Reduce_scatter_block()");
  if (rank == 0) $free(tmpbuf);
  return 0;
}

int MPI_Reduce_scatter
(const void *sendbuf, void *recvbuf, const int recvcounts[],
 MPI_Datatype datatype, MPI_Op op, MPI_Comm comm)
{
  int nprocs = $mpi_comm_size(comm), rank = $mpi_comm_place(comm);
  int total_count = 0, displs[nprocs];
  _Bool inplace = sendbuf == MPI_IN_PLACE;
  checkInit();
  $cmon_check_1_n($mpi_get_cmon(comm), REDUCE_SCATTER_TAG, inplace,
		  MPI_TSIG_NULL,
		  (($mpi_tsig[nprocs])$lambda (int i)
		   ($mpi_tsig){ .count=recvcounts[i], .type=datatype }),
		  op, -1);
  //  $mpi_check_buffer(sendbuf, recvcounts[rank], datatype);
  for (int i = 0; i < nprocs; i++) {
    displs[i] = total_count;
    total_count += recvcounts[i];
  }
  void * tmpbuf = rank == 0  ? $mpi_malloc($mpi_proc_scope(comm), total_count, datatype) : NULL;
  const void * sbuf = inplace ? recvbuf : sendbuf;
  $assert(0 <= op && op <= 13, "unknown MPI reduce operation");
  // refer to op.h & mpi.h in ABC/src/include for how MPI_Op is defined
  reduce(sbuf, tmpbuf, total_count, datatype, op, 0,
	 REDUCE_SCATTER_TAG, comm, "MPI_Reduce_scatter()");
  scatterv(tmpbuf, recvcounts, displs, datatype, recvbuf,
	   recvcounts[rank], datatype, 0, REDUCE_SCATTER_TAG, comm,
	   "MPI_Reduce_scatter()");
  if (rank == 0) $free(tmpbuf);
  return 0;
}

int MPI_Scan(const void *sendbuf, void *recvbuf, int count,
	     MPI_Datatype datatype, MPI_Op op, MPI_Comm comm) {
  int nprocs = $mpi_comm_size(comm), rank = $mpi_comm_place(comm);
  int sz = sizeofDatatype(datatype);
  _Bool inplace = sendbuf == MPI_IN_PLACE;
  
  checkInit();
  $cmon_check_1($mpi_get_cmon(comm), SCAN_TAG, inplace,
		($mpi_tsig){.count=count, .type=datatype},
		op, -1);
  //  if (!inplace)
  //    $mpi_check_buffer(sendbuf, count, datatype);
  //  $mpi_check_buffer(recvbuf, count, datatype);
  if (rank == 0) {
    if (!inplace) {
      $mpi_memcpy(recvbuf, sendbuf, count, datatype);
    }
  } else if (inplace) { // rank>0 && inplace
    void * tmpbuf = $mpi_malloc($mpi_proc_scope(comm), count, datatype);
    $mpi_collective_recv(tmpbuf, count, datatype, rank-1, SCAN_TAG, comm,
			 MPI_STATUS_IGNORE, "MPI_Scan()");
    apply(recvbuf, count, datatype, op, tmpbuf, recvbuf);
    $free(tmpbuf);
  } else { // rank>0 && !inplace
    $mpi_collective_recv(recvbuf, count, datatype, rank-1, SCAN_TAG, comm,
			 MPI_STATUS_IGNORE, "MPI_Scan()");
    apply(recvbuf, count, datatype, op, (void*)sendbuf, recvbuf);
  }
  if (rank < nprocs - 1)
    $mpi_collective_send(recvbuf, count, datatype, rank+1, SCAN_TAG, comm);
  return 0;
}


int MPI_Exscan(const void *sendbuf, void *recvbuf, int count,
	       MPI_Datatype datatype, MPI_Op op, MPI_Comm comm) {
  int nprocs = $mpi_comm_size(comm), rank = $mpi_comm_place(comm);
  int sz = sizeofDatatype(datatype);
  _Bool inplace = sendbuf == MPI_IN_PLACE;
  
  checkInit();
  $cmon_check_1($mpi_get_cmon(comm), EXSCAN_TAG, sendbuf==MPI_IN_PLACE,
		($mpi_tsig){.count=count, .type=datatype},
		op, -1);
  //  if (inplace && rank < nprocs)
  //    $mpi_check_buffer(sendbuf, count, datatype);
  //  if (rank > 0 || inplace)
  //    $mpi_check_buffer(recvbuf, count, datatype);
  
  if (rank == 0) {
    if (nprocs > 1)
      $mpi_collective_send((inplace ? recvbuf : sendbuf), count, datatype,
			   1, EXSCAN_TAG, comm);
  } else if (rank < nprocs - 1) { // 0<rank<nprocs-1
    if (inplace) {
      void * tmpbuf = $mpi_malloc($mpi_proc_scope(comm), count, datatype);
      $mpi_memcpy(tmpbuf, recvbuf, count, datatype);
      $mpi_collective_recv(recvbuf, count, datatype, rank-1, EXSCAN_TAG,
			   comm, MPI_STATUS_IGNORE, "MPI_Exscan()");
      apply(tmpbuf, count, datatype, op, recvbuf, tmpbuf);
      $mpi_collective_send(tmpbuf, count, datatype, rank+1, EXSCAN_TAG, comm);
      $free(tmpbuf);
    } else {
      void * tmpbuf = $mpi_malloc($mpi_proc_scope(comm), count, datatype);
      $mpi_collective_recv(recvbuf, count, datatype, rank-1, EXSCAN_TAG,
			   comm, MPI_STATUS_IGNORE, "MPI_Exscan()");
      apply(tmpbuf, count, datatype, op, recvbuf, (void*)sendbuf);
      $mpi_collective_send(tmpbuf, count, datatype, rank+1, EXSCAN_TAG, comm);
      $free(tmpbuf);
    }
  } else { // 0<rank==nprocs-1
    $mpi_collective_recv(recvbuf, count, datatype, rank-1, EXSCAN_TAG,
			 comm, MPI_STATUS_IGNORE, "MPI_Exscan()");
  }
  return 0;
}

/* ****************** End of collective routines  ********************* */

int MPI_Comm_dup(MPI_Comm comm, MPI_Comm * newcomm) {
  checkInit();
  $scope CMPI_PROC_SCOPE = $mpi_proc_scope(comm);
  $mpi_comm_dup(CMPI_PROC_SCOPE, comm, newcomm, "MPI_Comm_dup");
  return 0;
}

int MPI_Comm_free(MPI_Comm * comm) {
  checkInit();
  $assert($is_derefable_pointer(comm), "The argument of MPI_Comm_free is NULL.");
  $mpi_comm_free(comm, _mpi_state);
  return 0;
}

int MPI_Init_thread( int *argc, char ***argv, int required, int *provided ) {
  _mpi_state = _MPI_INIT;
  *provided = MPI_THREAD_MULTIPLE;
  return MPI_SUCCESS;
}

#endif
