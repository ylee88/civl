
#include <mpi-defs.cvh>
#include <pointer.cvh>
#include <string.h>


struct IntInt {
  int x;
  int y;
};

struct RealInt {
  $real x;
  int y;
};

struct RealReal {
  $real x;
  $real y;
};

/* Returns the string literal of certain MPI routine names by giving
   the unique message tag. */
char * $mpi_coroutine_name(int tag) {
  switch(tag) {
    // collectives...
  case ALLGATHER_TAG: return "MPI_Allgather";
  case ALLGATHERV_TAG: return "MPI_Allgatherv";
  case ALLREDUCE_TAG: return "MPI_Allreduce";
  case ALLTOALLV_TAG: return "MPI_Alltoallv";
  case ALLTOALLW_TAG: return "MPI_Alltoallw";
  case ALLTOALL_TAG: return "MPI_Alltoall";
  case BARRIER_TAG: return "MPI_Barrier";
  case BCAST_TAG: return "MPI_Bcast"; 
  case EXSCAN_TAG: return "MPI_Exscan";
  case GATHERV_TAG: return "MPI_Gatherv";
  case GATHER_TAG: return "MPI_Gather";
  case REDUCE_TAG: return "MPI_Reduce";
  case REDUCE_SCATTER_BLOCK_TAG: return "MPI_Reduce_scatter_block";
  case REDUCE_SCATTER_TAG: return "MPI_Reduce_scatter";
  case SCAN_TAG: return "MPI_Scan";
  case SCATTERV_TAG: return "MPI_Scatterv";
  case SCATTER_TAG: return "MPI_Scatter";
    // other functions...
  case COMMDUP_TAG: return "MPI_Commdup";
  case COMMFREE_TAG: return "MPI_Commfree";
  default: $assert($false,
		   "Internal Error: Unexpected MPI routine tag:%d.\n", tag);
  }
}

$state_f size_t $mpi_extentof(MPI_Datatype datatype) {
  $abstract size_t $mpi_sizeof(MPI_Datatype datatype);
  return $mpi_sizeof(datatype);	  
}

int sizeofDatatype(MPI_Datatype datatype) {
  if (!$is_concrete_int(datatype))
    return $mpi_extentof(datatype);
  
  size_t result;

  // TODO: complete this list.  cover all cases
  switch (datatype) {
  case MPI_INT:
    result =  sizeof(int); break;
  case MPI_FLOAT:
    result =  sizeof(float); break;
  case MPI_DOUBLE:
    result =  sizeof(double); break;
  case MPI_CHAR:
    result =  sizeof(char); break;
  case MPI_BYTE:
    result =  sizeof(char); break; // char is always one byte ?
  case MPI_SHORT:
    result =  sizeof(short); break;
  case MPI_LONG:
    result =  sizeof(long); break;
  case MPI_LONG_DOUBLE:
    result =  sizeof(long double); break;
  case MPI_LONG_LONG_INT:
    result =  sizeof(long long int); break;
  case MPI_LONG_LONG:
    result =  sizeof(long long); break;
  case MPI_UNSIGNED_LONG_LONG:
    result =  sizeof(unsigned long long); break;
  case MPI_C_COMPLEX:
  case MPI_C_FLOAT_COMPLEX:
    result = sizeof(float _Complex); break;
  case MPI_C_DOUBLE_COMPLEX:
    result = sizeof(double _Complex); break;
  case MPI_C_LONG_DOUBLE_COMPLEX:
    result = sizeof(long double _Complex); break;
  case MPI_2INT:
  case MPI_2INTEGER:
  case MPI_SHORT_INT:
  case MPI_LONG_INT:
    result = sizeof(struct IntInt); break;
  case MPI_FLOAT_INT:
  case MPI_DOUBLE_INT:
  case MPI_LONG_DOUBLE_INT:
    result = sizeof(struct RealInt); break;
  case MPI_2REAL:
  case MPI_2DOUBLE_PRECISION:
    result = sizeof(struct RealReal); break;
  default:
    $assert(0, "Unreachable");
  }
  return result;
}

void * $mpi_malloc($scope scope, int count, MPI_Datatype datatype) {
  switch (datatype) {
  case MPI_INT:
  case MPI_SHORT:
  case MPI_LONG:
  case MPI_LONG_LONG_INT:
  case MPI_LONG_LONG:
  case MPI_UNSIGNED_LONG_LONG:
    return (int *)$malloc(scope, sizeof(int) * count);
  case MPI_FLOAT:
  case MPI_DOUBLE:
  case MPI_LONG_DOUBLE:
    return ($real *)$malloc(scope, count * sizeof($real));
  case MPI_CHAR:
  case MPI_BYTE:
    return (char *)$malloc(scope, count * sizeof(char));
  case MPI_C_COMPLEX:
  case MPI_C_FLOAT_COMPLEX:
    return (float _Complex *)
      $malloc(scope, count * sizeof(float _Complex));
  case MPI_C_DOUBLE_COMPLEX:
    return (double _Complex *)
      $malloc(scope, count * sizeof(double _Complex));
  case MPI_C_LONG_DOUBLE_COMPLEX:
    return (long double _Complex *)
      $malloc(scope, count * sizeof(long double _Complex));
  case MPI_2INT:
  case MPI_2INTEGER:
  case MPI_SHORT_INT:
  case MPI_LONG_INT:
    return (struct IntInt *)
      $malloc(scope, count * sizeof(struct IntInt));
  case MPI_FLOAT_INT:
  case MPI_DOUBLE_INT:
  case MPI_LONG_DOUBLE_INT:
    return (struct RealInt *)
      $malloc(scope, count * sizeof(struct RealInt));
  case MPI_2REAL:
  case MPI_2DOUBLE_PRECISION:
    return (struct RealReal *)
      $malloc(scope, count * sizeof(struct RealReal));
  default:
    $assert(0, "Unreachable");
  }
  return (void *)0;
}

void * $mpi_pointer_add(const void * ptr, int offset, MPI_Datatype datatype) {
  if (ptr == NULL) return NULL;
  int type_size = sizeofDatatype(datatype);
  return $pointer_add(ptr, offset, type_size);
}

$message $mpi_convert_pack(int src, const void *buf, int count,
			   MPI_Datatype datatype, int dest, int tag) {
  switch (datatype) {
  case MPI_2INT:
  case MPI_2INTEGER:
  case MPI_SHORT_INT:
  case MPI_LONG_INT: {
    struct IntInt * p = (struct IntInt *)buf;
    struct IntInt tmp[count];
    for (int i=0; i<count; i++) {
      tmp[i].x = p[i].x;
      tmp[i].y = p[i].y;
    }
    return $message_pack(src, dest, tag, tmp, count*sizeof(struct IntInt));
  }
  case MPI_FLOAT_INT:
  case MPI_DOUBLE_INT:
  case MPI_LONG_DOUBLE_INT: {
    struct RealInt * p = (struct RealInt *)buf;
    struct RealInt tmp[count];
    for (int i=0; i<count; i++) {
      tmp[i].x = p[i].x;
      tmp[i].y = p[i].y;
    }
    return $message_pack(src, dest, tag, tmp, count*sizeof(struct RealInt));
  }
  case MPI_2REAL:
  case MPI_2DOUBLE_PRECISION: {
    struct RealReal * p = (struct RealReal *)buf;
    struct RealReal tmp[count];
    for (int i=0; i<count; i++) {
      tmp[i].x = p[i].x;
      tmp[i].y = p[i].y;
    }
    return $message_pack(src, dest, tag, tmp, count*sizeof(struct RealReal));
  }
  default:
    return $message_pack(src, dest, tag, buf, count*sizeofDatatype(datatype));
  } 
}

void $mpi_unpack_convert($message msg, void * buf, int count,
			 MPI_Datatype datatype) {
  switch (datatype) {
  case MPI_2INT:
  case MPI_2INTEGER:
  case MPI_SHORT_INT:
  case MPI_LONG_INT: {
    struct IntInt * p = (struct IntInt *)buf;
    struct IntInt tmp[count];
    $message_unpack(msg, tmp, count*sizeof(struct IntInt));
    for (int i=0; i<count; i++) {
      p[i].x = tmp[i].x;
      p[i].y = tmp[i].y;
    }
  }
    break;
  case MPI_FLOAT_INT:
  case MPI_DOUBLE_INT:
  case MPI_LONG_DOUBLE_INT: {
    struct RealInt * p = (struct RealInt *)buf;
    struct RealInt tmp[count];
    $message_unpack(msg, tmp, count*sizeof(struct RealInt));
    for (int i=0; i<count; i++) {
      p[i].x = tmp[i].x;
      p[i].y = tmp[i].y;
    }
  }
    break;
  case MPI_2REAL:
  case MPI_2DOUBLE_PRECISION: {
    struct RealReal * p = (struct RealReal *)buf;
    struct RealReal tmp[count];
    $message_unpack(msg, tmp, count*sizeof(struct RealReal));
    for (int i=0; i<count; i++) {
      p[i].x = tmp[i].x;
      p[i].y = tmp[i].y;
    }
  }
    break;
  default:
    $message_unpack(msg, buf, count*sizeofDatatype(datatype));
  } 
}

void $mpi_memcpy(void * p, const void * q, int count,
		 MPI_Datatype datatype) {
  if (count == 0) return;
  switch (datatype) {
  case MPI_2INT:
  case MPI_2INTEGER:
  case MPI_SHORT_INT:
  case MPI_LONG_INT: {
    struct IntInt *p1 = (struct IntInt *)p, *q1 = (struct IntInt *)q;
    for (int i=0; i<count; i++) {
      p1[i].x = q1[i].x;
      p1[i].y = q1[i].y;
    }
  }
    break;
  case MPI_FLOAT_INT:
  case MPI_DOUBLE_INT:
  case MPI_LONG_DOUBLE_INT: {
    struct RealInt *p1 = (struct RealInt *)p, *q1 = (struct RealInt *)q;
    for (int i=0; i<count; i++) {
      p1[i].x = q1[i].x;
      p1[i].y = q1[i].y;
    }
  }
    break;
  case MPI_2REAL:
  case MPI_2DOUBLE_PRECISION: {
    struct RealReal *p1 = (struct RealReal *)p, *q1 = (struct RealReal *)q;
    for (int i=0; i<count; i++) {
      p1[i].x = q1[i].x;
      p1[i].y = q1[i].y;
    }
  }
    break;
  default:
    memcpy(p, q, count*sizeofDatatype(datatype));
  }
}
