
#include <civlc.cvh>
#include <complex.cvh>
#include <math.h>

typedef struct $float_complex {
  float real;
  float imag;
} $float_complex;

typedef struct $double_complex {
  double real;
  double imag;
} $double_complex;

typedef struct $ldouble_complex {
  long double real;
  long double imag;
} $ldouble_complex;

// Constructors...

$double_complex CMPLX(double x, double y) {
  return ($double_complex){x, y};
}

$float_complex CMPLXF(float x, float y) {
  return ($float_complex){x, y};
}

$ldouble_complex CMPLXL(long double x, long double y) {
  return ($ldouble_complex){x, y};
}

// Print...

void $cprint($double_complex x) {
  $print_helper("", x.real, " + (", x.imag, ")i");
}

void $cprintf($float_complex x) {
  $print_helper("", x.real, " + (", x.imag, ")i");
}

void $cprintl($ldouble_complex x) {
  $print_helper("", x.real, " + (", x.imag, ")i");
}

// Eq and neq...

int $ceq($double_complex x, $double_complex y) {
  return (int)(x.real == y.real && x.imag == y.imag);
}

int $cneq($double_complex x, $double_complex y) {
  return (int)(x.real != y.real || x.imag != y.imag);
}

int $ceqf($float_complex x, $float_complex y) {
  return (int)(x.real == y.real && x.imag == y.imag);
}

int $cneqf($float_complex x, $float_complex y) {
  return (int)(x.real != y.real || x.imag != y.imag);
}

int $ceql($ldouble_complex x, $ldouble_complex y) {
  return (int)(x.real == y.real && x.imag == y.imag);
}

int $cneql($ldouble_complex x, $ldouble_complex y) {
  return (int)(x.real != y.real || x.imag != y.imag);
}

// add, sub, mul, div, neg...

$double_complex $cadd($double_complex x, $double_complex y) {
  return ($double_complex){x.real+y.real, x.imag+y.imag};
}

$double_complex $csub($double_complex x, $double_complex y) {
  return ($double_complex){x.real-y.real, x.imag-y.imag};
}

$double_complex $cmul($double_complex x, $double_complex y) {
  return ($double_complex){x.real*y.real - x.imag*y.imag,
      x.real*y.imag + x.imag*y.real};
}

$double_complex $cdiv($double_complex x, $double_complex y) {
  const double a = x.real, b = x.imag, c = y.real, d = y.imag,
    r = c*c+d*d;
  return ($double_complex){(a*c+b*d)/r, (b*c-a*d)/r};
}

$double_complex $cneg($double_complex x) {
  return ($double_complex){-x.real, -x.imag};
}




$float_complex $caddf($float_complex x, $float_complex y) {
  return ($float_complex){x.real+y.real, x.imag+y.imag};
}

$float_complex $csubf($float_complex x, $float_complex y) {
  return ($float_complex){x.real-y.real, x.imag-y.imag};
}

$float_complex $cmulf($float_complex x, $float_complex y) {
  return ($float_complex){x.real*y.real - x.imag*y.imag,
      x.real*y.imag + x.imag*y.real};
}

$float_complex $cdivf($float_complex x, $float_complex y) {
  const float a = x.real, b = x.imag, c = y.real, d = y.imag,
    r = c*c+d*d;
  return ($float_complex){(a*c+b*d)/r, (b*c-a*d)/r};
}

$float_complex $cnegf($float_complex x) {
  return ($float_complex){-x.real, -x.imag};
}

$ldouble_complex $caddl($ldouble_complex x, $ldouble_complex y) {
  return ($ldouble_complex){x.real+y.real, x.imag+y.imag};
}

$ldouble_complex $csubl($ldouble_complex x, $ldouble_complex y) {
  return ($ldouble_complex){x.real-y.real, x.imag-y.imag};
}

$ldouble_complex $cmull($ldouble_complex x, $ldouble_complex y) {
  return ($ldouble_complex){x.real*y.real - x.imag*y.imag,
      x.real*y.imag + x.imag*y.real};
}

$ldouble_complex $cdivl($ldouble_complex x, $ldouble_complex y) {
  const long double a = x.real, b = x.imag, c = y.real, d = y.imag,
    r = c*c+d*d;
  return ($ldouble_complex){(a*c+b*d)/r, (b*c-a*d)/r};
}

$ldouble_complex $cnegl($ldouble_complex x) {
  return ($ldouble_complex){-x.real, -x.imag};
}

$double_complex $cfloat2double($float_complex x) {
  return ($double_complex){(double)x.real, (double)x.imag};
}

$ldouble_complex $cfloat2ldouble($float_complex x) {
  return ($ldouble_complex){(long double)x.real, (long double)x.imag};
}

$float_complex $cdouble2float($double_complex x) {
  return ($float_complex){(float)x.real, (float)x.imag};
}

$ldouble_complex $cdouble2ldouble($double_complex x) {
  return ($ldouble_complex){(long double)x.real, (long double)x.imag};
}

$float_complex $cldouble2float($ldouble_complex x) {
  return ($float_complex){(float)x.real, (float)x.imag};
}

$double_complex $cldouble2double($ldouble_complex x) {
  return ($double_complex){(double)x.real, (double)x.imag};

}

_Bool $cfloat2bool($float_complex x) {
  return x.real != 0.0f || x.imag != 0.0f;
}

_Bool $cdouble2bool($double_complex x) {
  return x.real != 0.0 || x.imag != 0.0;
}

_Bool $cldouble2bool($ldouble_complex x) {
  return x.real != 0.0L || x.imag != 0.0L;
}

double cabs($double_complex x) {
  return sqrt(x.real*x.real + x.imag*x.imag);
}

float cabsf($float_complex x) {
  return sqrtf(x.real*x.real + x.imag*x.imag);
}

long double cabsl($ldouble_complex x) {
  return sqrtl(x.real*x.real + x.imag*x.imag);
}

double cimag($double_complex x) {
  return x.imag;
}

float cimagf($float_complex x) {
  return x.imag;
}

long double cimagl($ldouble_complex x) {
  return x.imag;
}

$double_complex conj($double_complex x) {
  return ($double_complex){x.real, -x.imag};
}

$float_complex conjf($float_complex x) {
  return ($float_complex){x.real, -x.imag};
}

$ldouble_complex conjl($ldouble_complex x) {
  return ($ldouble_complex){x.real, -x.imag};
}

double creal($double_complex x) {
  return x.real;
}

float crealf($float_complex x) {
  return x.real;
}

long double creall($ldouble_complex x) {
  return x.real;
}

