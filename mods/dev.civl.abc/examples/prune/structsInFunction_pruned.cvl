#pragma CIVL ACSL
//======================== civlc.cvh =======================
typedef struct $proc $proc;
/*@ depends_on \nothing;
  @*/
$system[civlc] void $wait($proc p);
//================== structsInFunction.cvl =================
void process() {
  int a;
  int b;
  a = b = 10;
}
int main() {
  $proc p = $spawn process();
  $wait(p);
}
