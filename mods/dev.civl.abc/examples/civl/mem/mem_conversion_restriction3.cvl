/* If an expression representing a set of pointers involves any kind
 *  of dereferencing pointer set, the expression is invalid.
 *  
 * Except that the expression has the form: &(*e) or &(a[e']) where e
 * has pointer-set type and a is a pointer/pointer-set
 */
struct T {
  int x[10];
};

int main() {
  struct T * t[10];
  struct T t2[10];
  
  $mem m = &(t[0]->x[0 .. 9]); // allowed, dereference a pointer
  m = &((t2[0 .. 9]).x);
  m = &(t[0]->x[0 .. 9]) + (0 .. 9);
}
