#ifndef _MPI_DEFS
#define _MPI_DEFS
#pragma CIVL ACSL

#include <op.h>
#include <stddef.h>
#include <civlc.cvh>
#include <comm.cvh>

// Internal tags used to implement various MPI routines...
// Collectives...
#define ALLGATHER_TAG    1
#define ALLGATHERV_TAG   2
#define ALLREDUCE_TAG    3
#define ALLTOALLV_TAG    4
#define ALLTOALLW_TAG    5
#define ALLTOALL_TAG     6
#define BARRIER_TAG      7
#define BCAST_TAG        8
#define EXSCAN_TAG       9
#define GATHERV_TAG      10
#define GATHER_TAG       11
#define REDUCE_TAG       12
#define REDUCE_SCATTER_BLOCK_TAG 13
#define REDUCE_SCATTER_TAG  14
#define SCAN_TAG         15
#define SCATTERV_TAG     16
#define SCATTER_TAG      17
// Other functions...
#define COMMDUP_TAG      100
#define COMMFREE_TAG     101

/* Note: this list must be copied verbatim into LibmpiEvaluator.java */
typedef enum MPI_Datatype {
    MPI_CHAR,
    MPI_CHARACTER,
    MPI_SIGNED_CHAR,           
    MPI_UNSIGNED_CHAR,
    MPI_BYTE,           
    MPI_WCHAR,          
    MPI_SHORT,          
    MPI_UNSIGNED_SHORT,
    MPI_INT,            
    MPI_INT16_T,
    MPI_INT32_T,
    MPI_INT64_T,
    MPI_INT8_T,
    MPI_INTEGER,
    MPI_INTEGER1,
    MPI_INTEGER16,
    MPI_INTEGER2,
    MPI_INTEGER4,
    MPI_INTEGER8,
    MPI_UNSIGNED,       
    MPI_LONG,          
    MPI_UNSIGNED_LONG, 
    MPI_FLOAT,          
    MPI_DOUBLE,         
    MPI_LONG_DOUBLE,
    MPI_LONG_LONG_INT,  
    MPI_UNSIGNED_LONG_LONG,
    MPI_LONG_LONG,
    MPI_PACKED,
    MPI_LB,
    MPI_UB,
    MPI_UINT16_T,
    MPI_UINT32_T,
    MPI_UINT64_T,
    MPI_UINT8_T,
    MPI_FLOAT_INT,        
    MPI_DOUBLE_INT,       
    MPI_LONG_INT,         
    MPI_SHORT_INT,        
    MPI_2INT,             
    MPI_LONG_DOUBLE_INT,  
    MPI_AINT,
    MPI_OFFSET,
    MPI_2DOUBLE_PRECISION,
    MPI_2INTEGER,
    MPI_2REAL,
    MPI_C_BOOL,
    MPI_C_COMPLEX,
    MPI_C_DOUBLE_COMPLEX,
    MPI_C_FLOAT_COMPLEX,
    MPI_C_LONG_DOUBLE_COMPLEX,
    MPI_COMPLEX,
    MPI_COMPLEX16,
    MPI_COMPLEX32,
    MPI_COMPLEX4,
    MPI_COMPLEX8,
    MPI_REAL,
    MPI_REAL16,
    MPI_REAL2,
    MPI_REAL4,
    MPI_REAL8
} MPI_Datatype;

#define MPI_DATATYPE_NULL (-1)


#define  MPIX_NO_OP  _NO_OP
#define  MPI_MAX     _MAX 
#define  MPI_MIN     _MIN     
#define  MPI_SUM     _SUM
#define  MPI_PROD    _PROD
#define  MPI_LAND    _LAND   
#define  MPI_BAND    _BAND   
#define  MPI_LOR     _LOR     
#define  MPI_BOR     _BOR     
#define  MPI_LXOR    _LXOR    
#define  MPI_BXOR    _BXOR    
#define  MPI_MINLOC  _MINLOC  
#define  MPI_MAXLOC  _MAXLOC  
#define  MPI_REPLACE _REPLACE

#define MPI_OP_NULL  (-1)

#define MPI_IDENT     0
#define MPI_CONGRUENT 1
#define MPI_SIMILAR   2
#define MPI_UNEQUAL   3


typedef enum Operation MPI_Op;

/* The state of an MPI process: uninitialized before MPI_Init is
   called, initialized after MPI_Init but before MPI_Finalize, and
   finalized after MPI_Finalize.  There is a global variable of this
   type declared in mpi.cvl. */
typedef enum _mpi_state {
  _MPI_UNINIT,
  _MPI_INIT,
  _MPI_FINALIZED
} $mpi_state;


/* Simple representation of a type signature: a count and MPI
   datatype.  TODO: generalize this to represent arbitrary type
   signatures. */
typedef struct $mpi_tsig {
  int count;
  MPI_Datatype type;
} $mpi_tsig;

#define MPI_TSIG_NULL (($mpi_tsig){.count=-1, .type=MPI_DATATYPE_NULL})

/* Returns the string literal of certain MPI routine names by giving
   the unique message tag. */
char * $mpi_coroutine_name(int tag);

/*@ pure;
  @ depends_on \nothing;
  @ executes_when \true;
  @*/
$state_f $atomic_f int sizeofDatatype(MPI_Datatype);

/* Returns the number of chars of the given MPI_Datatype.  equivalent
 * to returns (datatypeSizeof(datatype) / sizeof(char)) */
$state_f size_t $mpi_extentof(MPI_Datatype);

/* Allocate memory space with MPI type signitures. Returns a pointer
   to the allocated memory space */
void * $mpi_malloc($scope scope, int count, MPI_Datatype datatype);

/* Computes the point that is count units after p, where a unit is one
   element of type datatype.  Special case: if count is 0, this
   function returns p, even if p is NULL.  This is to handle nicely
   the special case where a send or receive buffer is NULL. */
void* $mpi_pointer_add(const void * p, int count, MPI_Datatype datatype);

/* Assert that the basetype of the object pointed by 'buf' is sames as
   the basetype of the 'datatype'. Here a basetype of an MPI_Datatype
   means a indivisiable MPI_datatype, e.g. the basetype of MPI_2INT is
   MPI_INT.*/
/*@ depends_on \access(buf);
  @ executes_when \true;
  @*/
$system[mpi] void $mpi_check_buffer(const void * buf, int count,
				    MPI_Datatype datatype);

/* Abstract function used to represent wall time. */
$abstract double $mpi_time(int i);

/* Packs the buffer into a message, and for the special MPI pair
   datatypes, like MPI_2INT, converts to the fixed MPI struct type. */
$message $mpi_convert_pack(int src, const void *buf, int count,
			   MPI_Datatype datatype, int dest, int tag);

/* Unpacks the message into buf, but for the special MPI pair
   datatypes, like MPI_2INT, first converts from the fixed MPI struct
   type. */
void $mpi_unpack_convert($message msg, void * buf, int count,
			 MPI_Datatype datatype);

void $mpi_memcpy(void * p, const void * q, int count,
		 MPI_Datatype datatype);

#endif
