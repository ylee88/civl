#ifndef _MPI_DEFS
#define _MPI_DEFS

#include <op.h>

#define ALLGATHER_TAG    1
#define ALLGATHERV_TAG   2
#define ALLREDUCE_TAG    3
#define ALLTOALLV_TAG    4
#define ALLTOALLW_TAG    5
#define ALLTOALL_TAG     6
#define BARRIER_TAG      7
#define BCAST_TAG        8
#define EXSCAN_TAG       9
#define GATHERV_TAG      10
#define GATHER_TAG       11
#define REDUCE_TAG       12
#define REDUCE_SCATTER_BLOCK_TAG 13
#define REDUCE_SCATTER_TAG  14
#define SCAN_TAG         15
#define SCATTERV_TAG     16
#define SCATTER_TAG      17

typedef enum MPI_Datatype {
    MPI_CHAR,
    MPI_CHARACTER,
    MPI_SIGNED_CHAR,           
    MPI_UNSIGNED_CHAR,
    MPI_BYTE,           
    MPI_WCHAR,          
    MPI_SHORT,          
    MPI_UNSIGNED_SHORT,
    MPI_INT,            
    MPI_INT16_T,
    MPI_INT32_T,
    MPI_INT64_T,
    MPI_INT8_T,
    MPI_INTEGER,
    MPI_INTEGER1,
    MPI_INTEGER16,
    MPI_INTEGER2,
    MPI_INTEGER4,
    MPI_INTEGER8,
    MPI_UNSIGNED,       
    MPI_LONG,          
    MPI_UNSIGNED_LONG, 
    MPI_FLOAT,          
    MPI_DOUBLE,         
    MPI_LONG_DOUBLE,
    MPI_LONG_LONG_INT,  
    MPI_UNSIGNED_LONG_LONG,
    MPI_LONG_LONG,
    MPI_PACKED,
    MPI_LB,
    MPI_UB,
    MPI_UINT16_T,
    MPI_UINT32_T,
    MPI_UINT64_T,
    MPI_UINT8_T,
    MPI_FLOAT_INT,        
    MPI_DOUBLE_INT,       
    MPI_LONG_INT,         
    MPI_SHORT_INT,        
    MPI_2INT,             
    MPI_LONG_DOUBLE_INT,  
    MPI_AINT,
    MPI_OFFSET,
    MPI_2DOUBLE_PRECISION,
    MPI_2INTEGER,
    MPI_2REAL,
    MPI_C_BOOL,
    MPI_C_COMPLEX,
    MPI_C_DOUBLE_COMPLEX,
    MPI_C_FLOAT_COMPLEX,
    MPI_C_LONG_DOUBLE_COMPLEX,
    MPI_COMPLEX,
    MPI_COMPLEX16,
    MPI_COMPLEX32,
    MPI_COMPLEX4,
    MPI_COMPLEX8,
    MPI_REAL,
    MPI_REAL16,
    MPI_REAL2,
    MPI_REAL4,
    MPI_REAL8
} MPI_Datatype;

#define MPI_DATATYPE_NULL (-1)


#define  MPIX_NO_OP  _NO_OP
#define  MPI_MAX     _MAX 
#define  MPI_MIN     _MIN     
#define  MPI_SUM     _SUM
#define  MPI_PROD    _PROD
#define  MPI_LAND    _LAND   
#define  MPI_BAND    _BAND   
#define  MPI_LOR     _LOR     
#define  MPI_BOR     _BOR     
#define  MPI_LXOR    _LXOR    
#define  MPI_BXOR    _BXOR    
#define  MPI_MINLOC  _MINLOC  
#define  MPI_MAXLOC  _MAXLOC  
#define  MPI_REPLACE _REPLACE

#define MPI_OP_NULL  (-1)

#define MPI_IDENT     0
#define MPI_CONGRUENT 1
#define MPI_SIMILAR   2
#define MPI_UNEQUAL   3

typedef enum Operation MPI_Op;

/* Simple representation of a type signature: a count and MPI
   datatype.  TODO: generalize this to represent arbitrary type
   signatures. */
typedef struct $mpi_tsig {
  int count;
  MPI_Datatype type;
} $mpi_tsig;

#define MPI_TSIG_NULL (($mpi_tsig){.count=-1, .type=MPI_DATATYPE_NULL})

#endif
