#ifndef _CIVLMPI_
#define _CIVLMPI_
/* Filename : civl-mpi.cvh

   This header file extends the standard MPI header file (mpi.h) with
   auxiliary functions and types to help implement an MPI library.

   Currently there are two separate implementations of this interface:
   civl-mpi-blocking.cvl (optimized for programs that only require MPI
   blocking communication) and civl-mpi-nonblocking.cvl (more general,
   supports nonblocking operations, but also less optimized).
 */
#include <bundle.cvh>
#include <cmon.cvh>
#include <comm.cvh>
#include <concurrency.cvh>
#include <mpi.h>
#include <mpi-defs.cvh>
#include <stddef.h>

// Note: the following header files are empty but are here to trigger
// linkage with the appropriate implementation file, either
// civl-mpi-nonblocking.cvl or civl-mpi-blocking.cvl...
#ifdef _MPI_NON_BLOCKING
#include <civl-mpi-nonblocking.cvh>
#elif defined(_MPI_BLOCKING)
#include <civl-mpi-blocking.cvh>
#endif
#pragma CIVL ACSL // ACSL contracts are used in this file


// Preprocessor macros...

// Internal tags used to implement various MPI routines...
// Other functions...
#define COMMDUP_TAG      100
#define COMMFREE_TAG     101

// Type definitions...

/* The state of an MPI process: uninitialized before MPI_Init is
   called, initialized after MPI_Init but before MPI_Finalize, and
   finalized after MPI_Finalize.  There is a global variable of this
   type declared in mpi.cvl. */
typedef enum _mpi_state {
  _MPI_UNINIT,
  _MPI_INIT,
  _MPI_FINALIZED
} $mpi_state;

/* This structure is used to store the global (shared) states of an
   MPI communicator. */
typedef struct $mpi_gcomm $mpi_gcomm;

// Misc. MPI support functions...

/* Abstract function used to represent wall time. */
$abstract double $mpi_time(int i);

/*@ pure;
  @ depends_on \nothing;
  @ executes_when \true;
  @*/
$state_f $atomic_f int sizeofDatatype(MPI_Datatype);

/* Returns the number of chars of the given MPI_Datatype.  equivalent
 * to returns (datatypeSizeof(datatype) / sizeof(char)) */
$state_f size_t $mpi_extentof(MPI_Datatype);

/* Allocate memory space with MPI type signitures. Returns a pointer
   to the allocated memory space */
void * $mpi_malloc(int count, MPI_Datatype datatype);

void* $mpi_pointer_add(const void*, int, MPI_Datatype);

/* Assert that the basetype of the object pointed by 'buf' is sames as
   the basetype of the 'datatype'. Here a basetype of an MPI_Datatype
   means a indivisiable MPI_datatype, e.g. the basetype of MPI_2INT is
   MPI_INT.*/
/*@ depends_on \access(buf);
  @ executes_when \true;
  @*/
$system[mpi] void $mpi_check_buffer(const void * buf, int count,
				    MPI_Datatype datatype);

// Communicator functions...

/* Creates a gcomm in the given scope, with the given number of
   processes. */
$mpi_gcomm $mpi_gcomm_create($scope, int);

/* Destroys the gcomm, deallocating any memory that was allocated when
   it was created. */
void $mpi_gcomm_destroy($mpi_gcomm);

/* Inserts the given gcomm into a list in a hidden variable
   _mpi_gcomms in the given scope (which should be the MPI root
   scope). */
/*@ depends_on \nothing;
  @ executes_when \true;
  @*/
$system[mpi] int $mpi_new_gcomm($scope, $mpi_gcomm);

/*@ depends_on \nothing;
  @ executes_when \true;
  @*/
$system[mpi] $mpi_gcomm $mpi_get_gcomm($scope, int);

/* Creates the MPI communicator object and returns handle.
   Arguments are scope for this process, the shared gcomm,
   and the rank of this process. */
MPI_Comm $mpi_comm_create($scope, $mpi_gcomm, int);

/* Destroys the MPI communicator object and sets handle to null
   value */
void $mpi_comm_destroy(MPI_Comm, $mpi_state);

int $mpi_comm_dup($scope, MPI_Comm, MPI_Comm *, char *);

/* Creates an MPI communicator MPI_COMM_SELF. The returned $mpi_gcomm
   needs to be explicitly destroyed. */
$mpi_gcomm $mpi_comm_self_create($scope, MPI_Comm * mpi_comm_self);

int $mpi_comm_free(MPI_Comm *, $mpi_state);


/*@ depends_on \nothing;
  @ executes_when \true;
  @*/
$atomic_f $state_f $cmon $mpi_get_cmon(MPI_Comm comm);

/* Returns the `$comm` object, representing the point-to-point
   channel, referred by the given MPI communicator handle.  */
/*@ depends_on \nothing;
  @ executes_when \true;
  @*/
$atomic_f $state_f $comm $mpi_get_p2p_channel(MPI_Comm comm);

/* Returns the `$comm` object, representing the collective channel,
   referred by the given MPI communicator handle.  */
/*@ depends_on \nothing;
  @ executes_when \true;
  @*/
$atomic_f $state_f $comm $mpi_get_col_channel(MPI_Comm comm);

/* Returns the number of processes in the given MPI communicator. */
/*@ depends_on \nothing;
  @ executes_when \true;
  @*/
$atomic_f $state_f int $mpi_comm_size(MPI_Comm comm);

/* Returns the place of the process owning the the given MPI
   communicator. */
/*@ depends_on \nothing;
  @ executes_when \true;
  @*/
$atomic_f $state_f int $mpi_comm_place(MPI_Comm comm);

/* Returns the root scope of all processes in the given MPI
   communicator. */
/*@ depends_on \nothing;
  @ executes_when \true;
  @*/
$atomic_f $state_f $scope $mpi_root_scope(MPI_Comm);

/* Returns the root scope of the process owning the given MPI
   communicator. */
/*@ depends_on \nothing;
  @ executes_when \true;
  @*/
$atomic_f $state_f $scope $mpi_proc_scope(MPI_Comm);

/*@ depends_on \nothing;
  @ executes_when \true;
  @*/
$system[mpi] $scope $mpi_root_scope_system($comm);

/*@ depends_on \nothing;
  @ executes_when \true;
  @*/
$system[mpi] $scope $mpi_proc_scope_system($comm);

// Point to point support functions...

int $mpi_send(const void *, int, MPI_Datatype, int, int, MPI_Comm);

int $mpi_recv(void *, int, MPI_Datatype, int, int, MPI_Comm, MPI_Status *);

int $mpi_isend(const void *buf, int count, MPI_Datatype datatype, int dest,
	       int tag, MPI_Comm comm, MPI_Request * request);

int $mpi_irecv(void *buf, int count, MPI_Datatype datatype, int source,
	       int tag, MPI_Comm comm, MPI_Request * request);

int $mpi_wait_send(MPI_Request * request, MPI_Status * status);

int $mpi_wait_recv(MPI_Request * request, MPI_Status * status);

int $mpi_wait(MPI_Request * request, MPI_Status * status);

int $mpi_sendrecv(const void *sendbuf, int sendcount, MPI_Datatype sendtype,
		  int dest, int sendtag, void *recvbuf, int recvcount, 
		  MPI_Datatype recvtype, int source, int recvtag,
		  MPI_Comm comm, MPI_Status *status);

// Collective support functions...

int $mpi_collective_send(const void *, int, MPI_Datatype, int, int, MPI_Comm);

int $mpi_collective_recv(void *, int, MPI_Datatype, int, int,
			 MPI_Comm, MPI_Status *, char *);

int $mpi_barrier(MPI_Comm);

int $mpi_bcast(void *, int, MPI_Datatype, int, int, MPI_Comm, char *);

int $mpi_reduce(const void*, void*, int,
		MPI_Datatype, MPI_Op, int, int,
		MPI_Comm, char *);

int $mpi_gather(const void*, int, MPI_Datatype, 
	       void*, int, MPI_Datatype, int, int, MPI_Comm, char *);

int $mpi_gatherv(const void*, int, MPI_Datatype,
		void*, const int[], const int[],
		 MPI_Datatype, int, int, 
		 MPI_Comm, char *);

int $mpi_scatter(const void*, int, MPI_Datatype, 
		 void*, int, MPI_Datatype, int,
		 int, MPI_Comm, char *);

int $mpi_scatterv(const void*, const int[], const
		 int[], MPI_Datatype, void* ,
		 int, MPI_Datatype, int, int,
		  MPI_Comm, char *);

int $mpi_scan(const void *, void *, int, MPI_Datatype, MPI_Op, MPI_Comm);

int $mpi_exscan(const void *, void *, int, MPI_Datatype, MPI_Op, MPI_Comm);

// Collective monitoring functions...

