/* This header file contains useful helper functions for manipulating
 * the CIVL versions of various Cuda objects.
 */

#ifndef _CUDA_HELPER_
#define _CUDA_HELPER_

#include <seq.cvh>
#include <mem.cvh>
#include <concurrency.cvh>
#include <comm.cvh>

extern $input int warpSize;

typedef struct {
  unsigned int x, y, z;
} dim3;

typedef struct {
  unsigned int x, y, z;
} uint3;

typedef struct $cuda_mem_set* $cuda_mem_set_t;
typedef struct $cuda_mem_set {
  $mem reads;
  $mem writes;
} $cuda_mem_set;

$cuda_mem_set_t $cuda_mem_set_create($scope scope);
void $cuda_mem_set_destroy($cuda_mem_set_t memSet);
void $cuda_mem_set_clear($cuda_mem_set_t memSet);
void $cuda_mem_set_add($cuda_mem_set_t memSet, $mem reads, $mem writes);

typedef enum {
  $CUDA_WARP_TAG_EMPTY,
  $CUDA_WARP_TAG_warpsync,
  $CUDA_WARP_TAG_shfl_sync,
  $CUDA_WARP_TAG_shfl_up_sync,
  $CUDA_WARP_TAG_shfl_down_sync,
  $CUDA_WARP_TAG_shfl_xor_sync,
  $CUDA_WARP_TAG_all_sync,
  $CUDA_WARP_TAG_any_sync,
  $CUDA_WARP_TAG_ballot_sync
} $cuda_warp_tag;

typedef struct $cuda_warp_data* $cuda_warp_data_t;
typedef struct $cuda_warp_data {
  int size;
  $cuda_mem_set_t** memSets;
  _Bool patching[];
  int num_alive;
  _Bool alive[];
  int num_in_barrier;
  _Bool in_barrier[];
  $cuda_warp_tag currOp;
  int reductionLane;
  $gcomm gcomm;
} $cuda_warp_data;

$cuda_warp_data_t $create_cuda_warp_data($scope warpScope, int size);
void $destroy_cuda_warp_data($cuda_warp_data_t warp);

typedef struct $cuda_block_data* $cuda_block_data_t;
typedef struct $cuda_block_data {
  int size;
  $cuda_mem_set_t* memSets;
  int predArray[];
  $gbarrier gbarrier;
  int currBarrierID;
  int numWarps;
  $cuda_warp_data_t* warps;
} $cuda_block_data;

$cuda_block_data_t $create_cuda_block_data($scope scope, int size);
void $destroy_cuda_block_data($cuda_block_data_t block);

typedef struct $cuda_kernel_data* $cuda_kernel_data_t;
typedef struct $cuda_kernel_data {
  int size;
  $cuda_mem_set_t* memSets;
  int numBlocks;
  $cuda_block_data_t* blocks;
} $cuda_kernel_data;

$cuda_kernel_data_t $create_cuda_kernel_data($scope scope, dim3 gridDim, dim3 blockDim);
void $destroy_cuda_kernel_data($cuda_kernel_data_t kernel);

typedef struct $cuda_thread_data* $cuda_thread_data_t;
typedef struct $cuda_thread_data {
  $cuda_kernel_data_t kernel;
  $cuda_block_data_t block;
  $cuda_warp_data_t warp;
  int blockID;
  int warpID;
  int laneID;
  $comm lane_comm;
  $barrier block_barrier;
} $cuda_thread_data;

// Dummy variable which will be shadowed by transformation code
$cuda_thread_data_t $thread;

$cuda_thread_data_t $create_cuda_thread_data($scope scope, $cuda_kernel_data_t kernel, int blockID, int warpID, int laneID);
/*@ depends_on \access(thread);
  @ executes_when \true;
  @ */
$atomic_f void $destroy_cuda_thread_data($cuda_thread_data_t thread);

/*@ depends_on \access(thread);
  @ executes_when \true;
  @*/
$atomic_f void $cuda_start_mem_patching($cuda_thread_data_t thread);
/*@ depends_on \access(thread);
  @ executes_when \true;
  @*/
$atomic_f void $cuda_update_patches($cuda_thread_data_t thread);
/*@ depends_on \access(thread);
  @ executes_when \true;
  @*/
$atomic_f void $cuda_end_mem_patching($cuda_thread_data_t thread);

/*@ depends_on \access(thread);
  @ executes_when \true;
  @*/
$atomic_f void $cuda_start_kernel_region($cuda_thread_data_t thread);
/*@ depends_on \access(thread);
  @ executes_when \true;
  @*/
$atomic_f void $cuda_complete_warp_region($cuda_thread_data_t thread);
/*@ depends_on \access(thread);
  @ executes_when \true;
  @*/
$atomic_f void $cuda_complete_block_region($cuda_thread_data_t thread);
/*@ depends_on \access(thread);
  @ executes_when \true;
  @*/
$atomic_f void $cuda_complete_kernel_region($cuda_thread_data_t thread);

/*@ depends_on \access(thread);
  @ executes_when \true;
  @ */
$atomic_f void $cuda_warp_barrier_enter($cuda_thread_data_t thread, $cuda_warp_tag tag);
/*@ depends_on \access(thread);
  @*/
$atomic_f void $cuda_warp_barrier_exit($cuda_thread_data_t thread);
void $cuda_warp_barrier_call($cuda_thread_data_t thread, $cuda_warp_tag tag);
void $cuda__syncthreads($cuda_thread_data_t thread, int barrierIndex);
int $cuda__syncthreads_count(int predicate, $cuda_thread_data_t thread, int barrierIndex);
int $cuda__syncthreads_or(int predicate, $cuda_thread_data_t thread, int barrierIndex);
int $cuda__syncthreads_and(int predicate, $cuda_thread_data_t thread, int barrierIndex);
void $cuda__syncwarp($cuda_thread_data_t thread);

int $cuda__shfl_sync_int(unsigned mask, int var, int laneParam, int width, $cuda_thread_data_t thread);
unsigned int $cuda__shfl_sync_uint(unsigned mask, unsigned int var, int laneParam, int width, $cuda_thread_data_t thread);
long $cuda__shfl_sync_long(unsigned mask, long var, int laneParam, int width, $cuda_thread_data_t thread);
unsigned long $cuda__shfl_sync_ulong(unsigned mask, unsigned long var, int laneParam, int width, $cuda_thread_data_t thread);
long long $cuda__shfl_sync_ll(unsigned mask, long long var, int laneParam, int width, $cuda_thread_data_t thread);
unsigned long long $cuda__shfl_sync_ull(unsigned mask, unsigned long long var, int laneParam, int width, $cuda_thread_data_t thread);
float $cuda__shfl_sync_float(unsigned mask, float var, int laneParam, int width, $cuda_thread_data_t thread);
double $cuda__shfl_sync_double(unsigned mask, double var, int laneParam, int width, $cuda_thread_data_t thread);

int $cuda__shfl_up_sync_int(unsigned mask, int var, int laneParam, int width, $cuda_thread_data_t thread);
unsigned int $cuda__shfl_up_sync_uint(unsigned mask, unsigned int var, int laneParam, int width, $cuda_thread_data_t thread);
long $cuda__shfl_up_sync_long(unsigned mask, long var, int laneParam, int width, $cuda_thread_data_t thread);
unsigned long $cuda__shfl_up_sync_ulong(unsigned mask, unsigned long var, int laneParam, int width, $cuda_thread_data_t thread);
long long $cuda__shfl_up_sync_ll(unsigned mask, long long var, int laneParam, int width, $cuda_thread_data_t thread);
unsigned long long $cuda__shfl_up_sync_ull(unsigned mask, unsigned long long var, int laneParam, int width, $cuda_thread_data_t thread);
float $cuda__shfl_up_sync_float(unsigned mask, float var, int laneParam, int width, $cuda_thread_data_t thread);
double $cuda__shfl_up_sync_double(unsigned mask, double var, int laneParam, int width, $cuda_thread_data_t thread);

int $cuda__shfl_down_sync_int(unsigned mask, int var, int laneParam, int width, $cuda_thread_data_t thread);
unsigned int $cuda__shfl_down_sync_uint(unsigned mask, unsigned int var, int laneParam, int width, $cuda_thread_data_t thread);
long $cuda__shfl_down_sync_long(unsigned mask, long var, int laneParam, int width, $cuda_thread_data_t thread);
unsigned long $cuda__shfl_down_sync_ulong(unsigned mask, unsigned long var, int laneParam, int width, $cuda_thread_data_t thread);
long long $cuda__shfl_down_sync_ll(unsigned mask, long long var, int laneParam, int width, $cuda_thread_data_t thread);
unsigned long long $cuda__shfl_down_sync_ull(unsigned mask, unsigned long long var, int laneParam, int width, $cuda_thread_data_t thread);
float $cuda__shfl_down_sync_float(unsigned mask, float var, int laneParam, int width, $cuda_thread_data_t thread);
double $cuda__shfl_down_sync_double(unsigned mask, double var, int laneParam, int width, $cuda_thread_data_t thread);

int $cuda__shfl_xor_sync_int(unsigned mask, int var, int laneParam, int width, $cuda_thread_data_t thread);
unsigned int $cuda__shfl_xor_sync_uint(unsigned mask, unsigned int var, int laneParam, int width, $cuda_thread_data_t thread);
long $cuda__shfl_xor_sync_long(unsigned mask, long var, int laneParam, int width, $cuda_thread_data_t thread);
unsigned long $cuda__shfl_xor_sync_ulong(unsigned mask, unsigned long var, int laneParam, int width, $cuda_thread_data_t thread);
long long $cuda__shfl_xor_sync_ll(unsigned mask, long long var, int laneParam, int width, $cuda_thread_data_t thread);
unsigned long long $cuda__shfl_xor_sync_ull(unsigned mask, unsigned long long var, int laneParam, int width, $cuda_thread_data_t thread);
float $cuda__shfl_xor_sync_float(unsigned mask, float var, int laneParam, int width, $cuda_thread_data_t thread);
double $cuda__shfl_xor_sync_double(unsigned mask, double var, int laneParam, int width, $cuda_thread_data_t thread);

int $cuda__all_sync(unsigned mask, int value, $cuda_thread_data_t thread);
int $cuda__any_sync(unsigned mask, int value, $cuda_thread_data_t thread);
unsigned $cuda__ballot_sync(unsigned mask, int value, $cuda_thread_data_t thread);

int $cuda_atomicAdd_int(int* address, int val, $cuda_thread_data_t thread);
unsigned int $cuda_atomicAdd_uint(unsigned int* address, unsigned int val, $cuda_thread_data_t thread);
unsigned long long int $cuda_atomicAdd_ullint(unsigned long long int* address,
                                        unsigned long long int val,
                                        $cuda_thread_data_t thread);
float $cuda_atomicAdd_float(float* address, float val, $cuda_thread_data_t thread);
double $cuda_atomicAdd_double(double* address, double val, $cuda_thread_data_t thread);

int $cuda_atomicSub_int(int* address, int val, $cuda_thread_data_t thread);
unsigned int $cuda_atomicSub_uint(unsigned int* address, unsigned int val, $cuda_thread_data_t thread);

int $cuda_atomicExch_int(int* address, int val, $cuda_thread_data_t thread);
unsigned int $cuda_atomicExch_uint(unsigned int* address, unsigned int val, $cuda_thread_data_t thread);
unsigned long long int $cuda_atomicExch_ullint(unsigned long long int* address,
                                  unsigned long long int val,
                                  $cuda_thread_data_t thread);
float $cuda_atomicExch_float(float* address, float val, $cuda_thread_data_t thread);

int $cuda_atomicMin_int(int* address, int val, $cuda_thread_data_t thread);
unsigned int $cuda_atomicMin_uint(unsigned int* address, unsigned int val, $cuda_thread_data_t thread);
unsigned long long int $cuda_atomicMin_ullint(unsigned long long int* address,
                                        unsigned long long int val,
                                        $cuda_thread_data_t thread);

int $cuda_atomicMax_int(int* address, int val, $cuda_thread_data_t thread);
unsigned int $cuda_atomicMax_uint(unsigned int* address, unsigned int val, $cuda_thread_data_t thread);
unsigned long long int $cuda_atomicMax_ullint(unsigned long long int* address,
                                        unsigned long long int val,
                                        $cuda_thread_data_t thread);

unsigned int $cuda_atomicInc(unsigned int* address, unsigned int val, $cuda_thread_data_t thread);

unsigned int $cuda_atomicDec(unsigned int* address, unsigned int val, $cuda_thread_data_t thread);

int $cuda_atomicCAS_int(int* address, int compare, int val, $cuda_thread_data_t thread);
unsigned int $cuda_atomicCAS_uint(unsigned int* address,
                            unsigned int compare,
                            unsigned int val,
                            $cuda_thread_data_t thread);
unsigned long long int $cuda_atomicCAS_ullint(unsigned long long int* address,
                                        unsigned long long int compare,
                                        unsigned long long int val,
                                        $cuda_thread_data_t thread);
unsigned short int $cuda_atomicCAS_usint(unsigned short int* address,
                                   unsigned short int compare,
                                   unsigned short int val,
                                   $cuda_thread_data_t thread);

int $cuda_atomicAnd_int(int* address, int val, $cuda_thread_data_t thread);
unsigned int $cuda_atomicAnd_uint(unsigned int* address,
                                 unsigned int val,
                                 $cuda_thread_data_t thread);
unsigned long long int $cuda_atomicAnd_ullint(unsigned long long int* address,
                                 unsigned long long int val,
                                 $cuda_thread_data_t thread);

int $cuda_atomicOr_int(int* address, int val, $cuda_thread_data_t thread);
unsigned int $cuda_atomicOr_uint(unsigned int* address,
                                 unsigned int val,
                                 $cuda_thread_data_t thread);
unsigned long long int $cuda_atomicOr_ullint(unsigned long long int* address,
                                 unsigned long long int val,
                                 $cuda_thread_data_t thread);

int $cuda_atomicXor_int(int* address, int val, $cuda_thread_data_t thread);
unsigned int $cuda_atomicXor_uint(unsigned int* address,
                                 unsigned int val,
                                 $cuda_thread_data_t thread);
unsigned long long int $cuda_atomicXor_ullint(unsigned long long int* address,
                                 unsigned long long int val,
                                 $cuda_thread_data_t thread);

// ------------------------------------------------

$gcomm $cuda_gcomm;
int $CUDA_PLACE_HOST;
int $CUDA_PLACE_DEVICE;
$comm $cuda_host_comm;

typedef struct $cuda_op_state* $cuda_op_state_t;
typedef struct $cuda_op_state {
	_Bool start;
	$proc op;
} $cuda_op_state;

typedef struct $cuda_op_state_node* $cuda_op_state_node_t;
typedef struct $cuda_op_state_node {
	$cuda_op_state_t opState;
	$cuda_op_state_node_t next;
} $cuda_op_state_node;

/* a type used to represent a CUDA stream
 */
typedef struct $cuda_stream_node* $cuda_stream_node_t;
typedef struct $cuda_stream* $cuda_stream_t;
typedef struct $cuda_stream {
	$cuda_op_state_node_t head;
	$cuda_op_state_node_t tail;
	int numOps;
	$cuda_stream_node_t containingNode;
	_Bool alive;
} $cuda_stream;
/* a type that wraps a stream for insertion into a list
 */
typedef struct $cuda_stream_node {
	$cuda_stream_t stream;
	$cuda_stream_node_t prev;
	$cuda_stream_node_t next;
} $cuda_stream_node;

/*@ depends_on \access(stream);
  @ assigns stream;
  @ reads \nothing;
  @*/
$atomic_f $proc $stream_enqueue($scope cudaScope, $cuda_stream_t stream, $message opParams, void(*opProc)($message, $cuda_op_state_t, $cuda_stream_t));
/*@ depends_on \nothing;
  @ assigns \nothing;
  @ reads \nothing;
  @*/
$atomic_f void $stream_dequeue($cuda_stream_t stream);

$cuda_stream_node_t $create_new_stream_node($scope cudaScope);
/*@ depends_on \nothing;
  @ assigns \nothing;
  @ reads \nothing;
  @*/
$atomic_f $proc $destroy_stream_node($cuda_stream_node_t node);

/* a type representing the state of a CUDA device
 */
typedef struct $cuda_context* $cuda_context_t;
typedef struct $cuda_context {
  $cuda_stream_node_t headNode;
  int numStreams;
} $cuda_context;

/**
 * Tags used for message-passing between host and device
 */
typedef enum $cuda_tag {
  // Predefined tags
  $CUDA_TAG_TEARDOWN,
  $CUDA_TAG_SCOPE_REQUEST,
  $CUDA_TAG_cudaFree,
  $CUDA_TAG_cudaMemcpy,
  $CUDA_TAG_cudaMemcpyAsync,
  $CUDA_TAG_cudaDeviceSynchronize
} $cuda_tag;

typedef enum {
  cudaMemcpyHostToHost,
  cudaMemcpyHostToDevice,
  cudaMemcpyDeviceToHost,
  cudaMemcpyDeviceToDevice,
  cudaMemcpyDefault
} cudaMemcpyKind;

typedef struct $cuda_memcpy_data {
  void* dst;
  const void* src;
  size_t count;
  cudaMemcpyKind kind;
} $cuda_memcpy_data;

// ------------------------------------------------

/* Computes the one dimensional index of a grid cell at a given location
 * in a three dimensional grid of a given size
 */
int $cuda_dim3_index (dim3 size, uint3 location);

/* Computes the one dimensional index of a specific thread in the grid given the
 * grid dimension, block dimension, block index, and thread index
 */
int $cuda_kernel_index (dim3 gDim, dim3 bDim, uint3 bIdx, uint3 tIdx);

/* Lifts a single integer x into a three dimensional vector representing
 * a one dimensional grid of length x
 */
dim3 $cuda_to_dim3(int x);

void $cuda_run_and_wait_on_procs(dim3 dim, void spawningFunction(uint3));

// ------------------------------------------------

