/* This header file contains useful helper functions for manipulating
 * the CIVL versions of various Cuda objects.
 */

#ifndef _CUDA_HELPER_
#define _CUDA_HELPER_

#include <seq.cvh>
#include <mem.cvh>
#include <concurrency.cvh>
#include <comm.cvh>

$gcomm $cuda_gcomm;
int $CUDA_PLACE_HOST;
int $CUDA_PLACE_DEVICE;
$comm $cuda_host_comm;

extern $input int warpSize;

typedef struct $cuda_op_state* $cuda_op_state_t;
typedef struct $cuda_op_state {
	_Bool start;
	$proc op;
} $cuda_op_state;

typedef struct $cuda_op_state_node* $cuda_op_state_node_t;
typedef struct $cuda_op_state_node {
	$cuda_op_state_t opState;
	$cuda_op_state_node_t next;
} $cuda_op_state_node;

/* a type used to represent a CUDA stream
 */
typedef struct $cuda_stream_node* $cuda_stream_node_t;
typedef struct $cuda_stream* $cuda_stream_t;
typedef struct $cuda_stream {
	$cuda_op_state_node_t head;
	$cuda_op_state_node_t tail;
	int numOps;
	$cuda_stream_node_t containingNode;
	_Bool alive;
} $cuda_stream;
/* a type that wraps a stream for insertion into a list
 */
typedef struct $cuda_stream_node {
	$cuda_stream_t stream;
	$cuda_stream_node_t prev;
	$cuda_stream_node_t next;
} $cuda_stream_node;

/*@ depends_on \access(stream);
  @ assigns stream;
  @ reads \nothing;
  @*/
$atomic_f $proc $stream_enqueue($scope cudaScope, $cuda_stream_t stream, $message opParams, void(*opProc)($message, $cuda_op_state_t, $cuda_stream_t));
/*@ depends_on \nothing;
  @ assigns \nothing;
  @ reads \nothing;
  @*/
$atomic_f void $stream_dequeue($cuda_stream_t stream);

$cuda_stream_node_t $create_new_stream_node($scope cudaScope);
/*@ depends_on \nothing;
  @ assigns \nothing;
  @ reads \nothing;
  @*/
$atomic_f $proc $destroy_stream_node($cuda_stream_node_t node);

/* a type representing the state of a CUDA device
 */
typedef struct $cuda_context* $cuda_context_t;
typedef struct $cuda_context {
  $cuda_stream_node_t headNode;
  int numStreams;
} $cuda_context;

/**
 * Tags used for message-passing between host and device
 */
typedef enum $cuda_tag {
  // Predefined tags
  $CUDA_TAG_TEARDOWN,
  $CUDA_TAG_SCOPE_REQUEST,
  $CUDA_TAG_cudaFree,
  $CUDA_TAG_cudaMemcpy,
  $CUDA_TAG_cudaMemcpyAsync,
  $CUDA_TAG_cudaDeviceSynchronize
} $cuda_tag;

/* type that bundles kernel-wide info
 */
typedef struct $cuda_kernel_instance* $cuda_kernel_instance_t;
typedef struct $cuda_kernel_instance {
  // Read and Write sets
  $mem* read_sets;
  $mem* write_sets;
  // Number of threads in kernel
  int size;
} $cuda_kernel_instance;

typedef struct {
  unsigned int x, y, z;
} dim3;

typedef struct {
  unsigned int x, y, z;
} uint3;

typedef enum {
  cudaMemcpyHostToHost,
  cudaMemcpyHostToDevice,
  cudaMemcpyDeviceToHost,
  cudaMemcpyDeviceToDevice,
  cudaMemcpyDefault
} cudaMemcpyKind;

$cuda_kernel_instance_t $create_kernel_instance($scope cudaScope, dim3 gridDim, dim3 blockDim);
void $destroy_kernel_instance($cuda_kernel_instance_t $kernel);

typedef struct $cuda_memcpy_data {
  void* dst;
  const void* src;
  size_t count;
  cudaMemcpyKind kind;
} $cuda_memcpy_data;

// ------------------------------------------------

/* Computes the one dimensional index of a grid cell at a given location
 * in a three dimensional grid of a given size
 */
int $cuda_dim3_index (dim3 size, uint3 location);

/* Computes the one dimensional index of a specific thread in the grid given the
 * grid dimension, block dimension, block index, and thread index
 */
int $cuda_kernel_index (dim3 gDim, dim3 bDim, uint3 bIdx, uint3 tIdx);

/* Lifts a single integer x into a three dimensional vector representing
 * a one dimensional grid of length x
 */
dim3 $cuda_to_dim3(int x);

void $cuda_run_and_wait_on_procs(dim3 dim, void spawningFunction(uint3));

// ------------------------------------------------

/* Checks data races
 */
$atomic_f void $check_data_race($cuda_kernel_instance_t k, int cur_tid);

/* Clears read and write memory sets of the given thread
*/
void $clear_mem_sets($cuda_kernel_instance_t k, int cur_tid);

void $clear_all_mem_sets($cuda_kernel_instance_t k);

/* Publishes current read a write sets to global arrays. Local sets are not cleared
*/
void $publish($cuda_kernel_instance_t k, int cur_tid);

// ------------------------------------------------

$message $cuda_free($message request);

void $cuda_memcpy_proc($message m, $cuda_op_state_t opState, $cuda_stream_t stream);
$message $cuda_memcpy($scope cudaScope, $cuda_stream_t stream, $message request, _Bool async);
void $cuda_host_memcpy(void* dst, const void* src, size_t count, cudaMemcpyKind kind, _Bool async);

$atomic_f $message $cuda_device_synchronize($cuda_context_t context);
void $cuda_host_device_synchronize();

$scope $cuda_host_request_device_scope();

// ------------------------------------------------

/* A barrier wrapper around barrier call that checks data races
 */
void $cuda_syncthreads($cuda_kernel_instance_t k, int kernel_id, $barrier g);

typedef struct $cuda_warp* $cuda_warp_t;
typedef struct $cuda_warp {
  int size;
  int num_alive;
  _Bool alive[];
  int num_in_barrier;
  _Bool in_barrier[];
  int reductionLane;
  $gcomm warp_gcomm;
} $cuda_warp;

$cuda_warp_t $create_cuda_warp($scope warpScope, int size);
void $destroy_cuda_warp($cuda_warp_t warp);

typedef struct $cuda_lane* $cuda_lane_t;
typedef struct $cuda_lane {
  int laneID;
  $cuda_warp_t warp;
  $comm lane_comm;
} $cuda_lane;

// Dummy variable which will be shadowed by transformation code
$cuda_lane_t $lane;

$cuda_lane_t $create_cuda_lane($scope laneScope, $cuda_warp_t warp, int laneID);
void $destroy_cuda_lane($cuda_lane_t lane);

int $cuda__shfl_sync_int(unsigned mask, int var, int laneParam, int width, $cuda_lane_t lane);
unsigned int $cuda__shfl_sync_uint(unsigned mask, unsigned int var, int laneParam, int width, $cuda_lane_t lane);
long $cuda__shfl_sync_long(unsigned mask, long var, int laneParam, int width, $cuda_lane_t lane);
unsigned long $cuda__shfl_sync_ulong(unsigned mask, unsigned long var, int laneParam, int width, $cuda_lane_t lane);
long long $cuda__shfl_sync_ll(unsigned mask, long long var, int laneParam, int width, $cuda_lane_t lane);
unsigned long long $cuda__shfl_sync_ull(unsigned mask, unsigned long long var, int laneParam, int width, $cuda_lane_t lane);
float $cuda__shfl_sync_float(unsigned mask, float var, int laneParam, int width, $cuda_lane_t lane);
double $cuda__shfl_sync_double(unsigned mask, double var, int laneParam, int width, $cuda_lane_t lane);

int $cuda__shfl_up_sync_int(unsigned mask, int var, int laneParam, int width, $cuda_lane_t lane);
unsigned int $cuda__shfl_up_sync_uint(unsigned mask, unsigned int var, int laneParam, int width, $cuda_lane_t lane);
long $cuda__shfl_up_sync_long(unsigned mask, long var, int laneParam, int width, $cuda_lane_t lane);
unsigned long $cuda__shfl_up_sync_ulong(unsigned mask, unsigned long var, int laneParam, int width, $cuda_lane_t lane);
long long $cuda__shfl_up_sync_ll(unsigned mask, long long var, int laneParam, int width, $cuda_lane_t lane);
unsigned long long $cuda__shfl_up_sync_ull(unsigned mask, unsigned long long var, int laneParam, int width, $cuda_lane_t lane);
float $cuda__shfl_up_sync_float(unsigned mask, float var, int laneParam, int width, $cuda_lane_t lane);
double $cuda__shfl_up_sync_double(unsigned mask, double var, int laneParam, int width, $cuda_lane_t lane);

int $cuda__shfl_down_sync_int(unsigned mask, int var, int laneParam, int width, $cuda_lane_t lane);
unsigned int $cuda__shfl_down_sync_uint(unsigned mask, unsigned int var, int laneParam, int width, $cuda_lane_t lane);
long $cuda__shfl_down_sync_long(unsigned mask, long var, int laneParam, int width, $cuda_lane_t lane);
unsigned long $cuda__shfl_down_sync_ulong(unsigned mask, unsigned long var, int laneParam, int width, $cuda_lane_t lane);
long long $cuda__shfl_down_sync_ll(unsigned mask, long long var, int laneParam, int width, $cuda_lane_t lane);
unsigned long long $cuda__shfl_down_sync_ull(unsigned mask, unsigned long long var, int laneParam, int width, $cuda_lane_t lane);
float $cuda__shfl_down_sync_float(unsigned mask, float var, int laneParam, int width, $cuda_lane_t lane);
double $cuda__shfl_down_sync_double(unsigned mask, double var, int laneParam, int width, $cuda_lane_t lane);

int $cuda__shfl_xor_sync_int(unsigned mask, int var, int laneParam, int width, $cuda_lane_t lane);
unsigned int $cuda__shfl_xor_sync_uint(unsigned mask, unsigned int var, int laneParam, int width, $cuda_lane_t lane);
long $cuda__shfl_xor_sync_long(unsigned mask, long var, int laneParam, int width, $cuda_lane_t lane);
unsigned long $cuda__shfl_xor_sync_ulong(unsigned mask, unsigned long var, int laneParam, int width, $cuda_lane_t lane);
long long $cuda__shfl_xor_sync_ll(unsigned mask, long long var, int laneParam, int width, $cuda_lane_t lane);
unsigned long long $cuda__shfl_xor_sync_ull(unsigned mask, unsigned long long var, int laneParam, int width, $cuda_lane_t lane);
float $cuda__shfl_xor_sync_float(unsigned mask, float var, int laneParam, int width, $cuda_lane_t lane);
double $cuda__shfl_xor_sync_double(unsigned mask, double var, int laneParam, int width, $cuda_lane_t lane);

int $cuda__all_sync(unsigned mask, int value, $cuda_lane_t lane);
int $cuda__any_sync(unsigned mask, int value, $cuda_lane_t lane);
unsigned $cuda__ballot_sync(unsigned mask, int value, $cuda_lane_t lane);

#endif

