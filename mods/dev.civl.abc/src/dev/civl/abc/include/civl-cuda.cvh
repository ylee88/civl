/* void $publish($cuda_kernel_instance_t k, int cur_tid); */

// ------------------------------------------------

$message $cuda_free($message request);

void $cuda_memcpy_proc($message m, $cuda_op_state_t opState, $cuda_stream_t stream);
$message $cuda_memcpy($scope cudaScope, $cuda_stream_t stream, $message request, _Bool async);
void $cuda_host_memcpy(void* dst, const void* src, size_t count, cudaMemcpyKind kind, _Bool async);

$atomic_f $message $cuda_device_synchronize($cuda_context_t context);
void $cuda_host_device_synchronize();

$scope $cuda_host_request_device_scope();

#endif

