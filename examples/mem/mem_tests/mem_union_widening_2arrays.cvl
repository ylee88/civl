#include<mem.cvh>

int a[10][10];
int b[10][10];
int main() {
  $mem m;

  m = &a[0 .. 3][0];
  m = $mem_union_widening(&b[5 .. 6][0], m);
  // no-op in such case:
  $assert($mem_contains(m, &a[0 .. 3][0]));  
  $assert($mem_contains(m, &b[5 .. 6][0]));  
  $assert(!$mem_contains(m, &a[4][0]));  
  $assert(!$mem_contains(m, &b[4][0]));  
}
