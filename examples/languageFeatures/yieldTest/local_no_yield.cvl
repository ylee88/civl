/*  Threads t0 and t1 are all wrapped in $local_begin and $local_end.
    Without $yield, only one interleave: t0 first then t1 will be
    explored by CIVL.  Hence the assertion violation will not be found
    (intended) by CIVL.
 */

int x = -1;

void thread(int tid) {
  $local_start();
  x = tid;
  $local_end();
}

int main() {
  $parfor (int i : 0 .. 1)
    thread(i);
  $assert(x == 1);
}
